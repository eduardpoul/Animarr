@page "/torrents/{Hash}/edit"
@rendermode InteractiveServer
@implements IDisposable
@using MonoTorrent.Client
@inject TorrentEngineService TorrentEngine
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IToastService ToastService
@inject NavigationManager Nav

<PageTitle>Animarr</PageTitle>

<div class="flex items-center mb-f-l gap-f-s">
    <FluentButton Appearance="Appearance.Stealth"
                  IconStart="@(new Icons.Regular.Size20.ArrowLeft())"
                  Title="@(L["torrent_edit.btn_back"])"
                  OnClick="@(() => Nav.NavigateTo("/torrents"))" />
    <FluentLabel Typo="Typography.H4" class="flex-1 truncate">@(_live?.Name ?? Hash)</FluentLabel>
    @if (_live is not null)
    {
        <div class="fluent-status-dot fluent-status-dot--@StateColorClass()" title="@_live.State.ToString()"></div>
        <span class="text-fluent-caption text-fluent-3">@_live.State</span>
    }
</div>

@if (_live is null)
{
    <FluentLabel Style="color:var(--neutral-foreground-hint);">@L["torrent_edit.not_found"]</FluentLabel>
}
else
{
    <div class="flex gap-f-xxl items-start flex-wrap">

        <!-- ── FILE TREE ─────────────────────────────────── -->
        <div class="flex-1 min-w-80">
            <div class="flex items-center mb-f-s gap-f-s">
                @if (_filesLoaded)
                {
                    <FluentCheckbox Value="@(_priorities.Count > 0 && _priorities.Values.All(v => v > 0))"
                                    ValueChanged="@((bool chk) => { foreach (var k in _priorities.Keys.ToList()) _priorities[k] = chk ? 4 : 0; StateHasChanged(); })" />
                }
                <FluentLabel Typo="Typography.H5" class="flex-1">
                    @L["torrent_edit.files_title"] @(_filesLoaded ? $"({_flatTree.Count(x => !x.IsFolder)})" : "")
                </FluentLabel>
                @if (_filesLoaded)
                {
                    <FluentButton Appearance="Appearance.Accent" Disabled="_saving" OnClick="SavePrioritiesAsync">
                        @(_saving ? L["torrent_edit.btn_saving"] : L["torrent_edit.btn_save"])
                    </FluentButton>
                }
            </div>

            @if (!_live.MetadataReceived)
            {
                <div style="display:flex;align-items:center;gap:10px;font-size:13px;color:var(--neutral-foreground-hint);padding:12px;">
                    <FluentProgress Width="80px" />
                    @L["torrent_edit.loading_metadata"]
                </div>
            }
            else if (_filesLoaded)
            {
                <div style="border:1px solid var(--neutral-stroke-rest);border-radius:4px;overflow:hidden;max-height:calc(100vh - 220px);overflow-y:auto;font-size:12px;">
                    @foreach (var item in _flatTree)
                    {
                        @if (IsItemVisible(item))
                        {
                        @if (item.IsFolder)
                        {
                            var fp = item.FullPath!;
                            var collapsed = _collapsedFolders.Contains(fp);
                            var folderChecked = IsFolderChecked(fp);
                <div class="flex items-center gap-f-s px-f-s py-f-xxs text-fluent-caption font-semibold border-b border-fluent-border-2"
                         style="background:var(--neutral-layer-2);padding-left:@(item.Depth * 12 + 6)px;cursor:pointer;user-select:none;"
                         @onclick="@(() => ToggleFolderCollapse(fp))">
                    <span class="text-fluent-caption w-3 text-center">@(collapsed ? "▶" : "▼")</span>
                    <FluentCheckbox Value="@folderChecked"
                                    @onclick:stopPropagation
                                    ValueChanged="@((bool _) => ToggleFolderCheck(fp))" />
                    <span>📁 @item.Name</span>
                </div>
                        }
                        else
                        {
                            var fp = item.FullPath!;
                            var prio = _priorities.GetValueOrDefault(fp, 4);
                            <div class="flex items-center gap-f-xxs border-b border-fluent-border-3"
                                 style="padding:3px 6px 3px @(item.Depth * 12 + 6)px;">
                                <FluentCheckbox Value="@(prio != 0)"
                                               ValueChanged="@((bool chk) => { _priorities[fp] = chk ? 4 : 0; StateHasChanged(); })" />
                                <span class="flex-1 truncate text-fluent-caption" title="@fp">@item.Name</span>
                                <span class="text-fluent-caption text-fluent-3 shrink-0 min-w-12 text-right">@FormatBytes(item.Length)</span>
                                <select style="font-size:11px;padding:1px 2px;border:1px solid var(--neutral-stroke-rest);border-radius:3px;background:var(--neutral-layer-floating);color:var(--neutral-foreground-rest);min-width:90px;opacity:@(prio == 0 ? "0.4" : "1");"
                                        value="@prio"
                                        @onchange="@(e => _priorities[fp] = int.Parse(e.Value!.ToString()!))">
                                    <option value="0">@L["file_priority.skip"]</option>
                                    <option value="2">@L["file_priority.low"]</option>
                                    <option value="4">@L["file_priority.normal"]</option>
                                    <option value="6">@L["file_priority.high"]</option>
                                </select>
                            </div>
                        }
                        }
                    }
                </div>
            }
        </div>

        <!-- ── SETTINGS SIDEBAR ──────────────────────────── -->
        <div class="w-70 shrink-0 flex flex-col gap-f-l">

            <!-- Speed limits -->
            <div class="fluent-card">
                <FluentLabel Typo="Typography.H5" class="mb-f-m">@L["torrent_edit.speed_title"]</FluentLabel>
                <FluentNumberField @bind-Value="_dlLimit" Label="@(L["torrent_edit.dl_limit_label"])" Min="0" style="width:100%;margin-bottom:10px;" />
                <FluentNumberField @bind-Value="_ulLimit" Label="@(L["torrent_edit.ul_limit_label"])" Min="0" style="width:100%;margin-bottom:10px;" />
                <FluentButton Appearance="Appearance.Accent" OnClick="ApplySpeedAsync">@L["torrent_edit.btn_apply"]</FluentButton>
            </div>

            <!-- Options -->
            <div class="fluent-card">
                <FluentLabel Typo="Typography.H5" class="mb-f-m">@L["torrent_edit.options_title"]</FluentLabel>
                <FluentSwitch Value="_stopAfterDownload" ValueChanged="OnStopAfterDownloadChanged">
                    @L["torrent_edit.stop_after_download"]
                </FluentSwitch>
                <div style="margin-top:10px;display:flex;align-items:center;gap:8px;opacity:0.65;">
                    <FluentSwitch Value="_skipSubfolderStructure" Disabled="true">@L["torrent_edit.flatten_subfolders"]</FluentSwitch>
                </div>
            </div>

            <!-- Stats -->
            <div class="fluent-card">
                <FluentLabel Typo="Typography.H5" class="mb-f-s">@L["torrent_edit.stats_title"]</FluentLabel>
                <div class="flex flex-col gap-f-xxs text-fluent-body">
                    <div style="display:flex;justify-content:space-between;">
                        <span style="color:var(--neutral-foreground-hint);">@L["torrent_edit.stat_progress"]</span>
                        <b>@_live.Progress.ToString("F1")%</b>
                    </div>
                    <FluentProgress Value="@((int)_live.Progress)" Max="100" Width="100%" />
                    <div style="display:flex;justify-content:space-between;margin-top:4px;">
                        <span style="color:var(--neutral-foreground-hint);">@L["torrent_edit.stat_downloaded"]</span>
                        <span>@FormatBytes(_live.Downloaded) / @FormatBytes(_live.TotalSize)</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;">
                        <span style="color:var(--neutral-foreground-hint);">@L["torrent_edit.stat_dl_speed"]</span>
                        <span>@FormatSpeed(_live.DownloadRate)</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;">
                        <span style="color:var(--neutral-foreground-hint);">@L["torrent_edit.stat_ul_speed"]</span>
                        <span>@FormatSpeed(_live.UploadRate)</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;">
                        <span style="color:var(--neutral-foreground-hint);">@L["torrent_edit.stat_peers"]</span>
                        <span>Seeds: @_live.Seeds &nbsp; Peers: @_live.Peers</span>
                    </div>
                    <FluentDivider Style="margin:6px 0;" />
                    <div style="font-size:11px;color:var(--neutral-foreground-hint);word-break:break-all;">
                        <div>@L["torrent_edit.path_label"] @_live.SavePath</div>
                        <div style="margin-top:4px;">@L["torrent_edit.hash_label"] @Hash[..Math.Min(20, Hash.Length)]…</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Hash { get; set; } = "";

    private TorrentLiveStats? _live;
    private bool _filesLoaded;
    private int _dlLimit;
    private int _ulLimit;
    private bool _stopAfterDownload;
    private bool _skipSubfolderStructure;
    private bool _saving;
    private bool _speedInitialized;

    private Dictionary<string, int> _priorities = new();
    private List<(bool IsFolder, string Name, string? FullPath, long Length, int Depth)> _flatTree = [];
    private HashSet<string> _collapsedFolders = new();

    protected override async Task OnInitializedAsync()
    {
        TorrentEngine.StateChanged += OnStateChanged;
        await LoadInitialDataAsync();
    }

    public void Dispose() => TorrentEngine.StateChanged -= OnStateChanged;

    private void OnStateChanged()
        => InvokeAsync(async () => { await RefreshAsync(); StateHasChanged(); });

    private async Task LoadInitialDataAsync()
    {
        _live = TorrentEngine.Get(Hash);
        if (_live is not null && !_speedInitialized)
        {
            _dlLimit = _live.DownloadLimit / 125000;
            _ulLimit = _live.UploadLimit / 125000;
            _speedInitialized = true;
        }

        // Load StopAfterDownload from DB
        await using var ctx = await DbFactory.CreateDbContextAsync();
        var record = await ctx.TorrentRecords.FirstOrDefaultAsync(r => r.InfoHash == Hash);
        if (record is not null)
        {
            _stopAfterDownload   = record.StopAfterDownload;
            _skipSubfolderStructure   = record.SkipSubfolderStructure;
        }

        TryLoadFiles();
    }

    private async Task RefreshAsync()
    {
        _live = TorrentEngine.Get(Hash);
        if (_live is not null && !_speedInitialized)
        {
            _dlLimit = _live.DownloadLimit / 125000;
            _ulLimit = _live.UploadLimit / 125000;
            _speedInitialized = true;
        }
        TryLoadFiles();
    }

    private void TryLoadFiles()
    {
        if (_filesLoaded || _live?.MetadataReceived != true) return;
        var files = TorrentEngine.GetFiles(Hash);
        if (files is null || files.Count == 0) return;

        var currentPrios = TorrentEngine.GetFilePriorities(Hash) ?? new();
        _priorities = files.ToDictionary(
            f => f.Path,
            f => currentPrios.TryGetValue(f.Path, out var p) ? p : 4);

        var entries = files.Select(f => new TorrentFileEntry(f.Path, f.Length));
        var tree = TorrentFileTree.BuildTree(entries);
        _flatTree = TorrentFileTree.Flatten(tree);
        _filesLoaded = true;
    }

    private async Task OnStopAfterDownloadChanged(bool value)
    {
        _stopAfterDownload = value;
        await TorrentEngine.SetStopAfterDownloadAsync(Hash, value);
        ToastService.ShowToast(ToastIntent.Success, L["torrent_edit.toast_saved"]);
    }

    private async Task SavePrioritiesAsync()
    {
        _saving = true;
        try
        {
            await TorrentEngine.SetFilePrioritiesBatchAsync(Hash, _priorities);
            ToastService.ShowToast(ToastIntent.Success, L["torrent_edit.toast_priorities_saved"]);
        }
        finally { _saving = false; }
    }

    private async Task ApplySpeedAsync()
    {
        await TorrentEngine.SetSpeedLimitsAsync(Hash, _dlLimit * 125000, _ulLimit * 125000);
        ToastService.ShowToast(ToastIntent.Success, L["torrent_edit.toast_limits_updated"]);
    }

    private bool IsItemVisible((bool IsFolder, string Name, string? FullPath, long Length, int Depth) item)
    {
        if (item.FullPath is null) return true;
        return !_collapsedFolders.Any(cf => item.FullPath.StartsWith(cf + "/"));
    }

    private bool IsFolderChecked(string folderPath)
    {
        var matches = _priorities.Where(kv => kv.Key.StartsWith(folderPath + "/") || kv.Key == folderPath).ToList();
        return matches.Count > 0 && matches.All(kv => kv.Value > 0);
    }

    private void ToggleFolderCheck(string folderPath)
    {
        bool allChecked = IsFolderChecked(folderPath);
        foreach (var key in _priorities.Keys.Where(k => k.StartsWith(folderPath + "/") || k == folderPath).ToList())
            _priorities[key] = allChecked ? 0 : 4;
        StateHasChanged();
    }

    private void ToggleFolderCollapse(string folderPath)
    {
        if (_collapsedFolders.Contains(folderPath)) _collapsedFolders.Remove(folderPath);
        else _collapsedFolders.Add(folderPath);
        StateHasChanged();
    }

    private string StateColorClass() => _live?.State switch
    {
        TorrentState.Downloading => "info",
        TorrentState.Metadata    => "info",
        TorrentState.Seeding     => "success",
        TorrentState.Paused      => "warning",
        TorrentState.Stopped     => "neutral",
        TorrentState.Error       => "error",
        TorrentState.Hashing     => "info",
        _                        => "neutral",
    };

    private static string FormatSpeed(long bps)
    {
        if (bps >= 1_048_576) return $"{bps / 1_048_576.0:F1} MB/s";
        if (bps >= 1024)      return $"{bps / 1024.0:F0} KB/s";
        return $"{bps} B/s";
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1_073_741_824) return $"{bytes / 1_073_741_824.0:F2} GB";
        if (bytes >= 1_048_576)     return $"{bytes / 1_048_576.0:F1} MB";
        if (bytes >= 1024)          return $"{bytes / 1024.0:F0} KB";
        return $"{bytes} B";
    }
}
