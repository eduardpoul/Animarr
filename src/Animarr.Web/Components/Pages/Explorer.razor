@page "/explorer"
@rendermode InteractiveServer
@implements IDisposable
@inject IDbContextFactory<AppDbContext> DbFactory
@inject FolderWatcherService WatcherService
@inject IRenameService RenameService
@inject IPatternMatchService Matcher
@inject IToastService ToastService

<PageTitle>Animarr</PageTitle>

<FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="margin-bottom:20px;gap:12px;">
    <FluentLabel Typo="Typography.H4" Style="margin:0;flex:1;">@L["explorer.title"]</FluentLabel>
    <FluentButton Appearance="Appearance.Accent"
                  IconStart="@(new Icons.Regular.Size20.Add())"
                  OnClick="@(() => OpenSectionDialog(null))">
        @L["explorer.add_section_button"]
    </FluentButton>
</FluentStack>

@if (_loading)
{
    <progress style="width:100%;height:4px;"></progress>
}
else if (_sections.Count == 0 && _standalone.Count == 0)
{
    <div style="text-align:center;padding:60px 20px;color:var(--neutral-foreground-hint);">
        <FluentIcon Value="@(new Icons.Regular.Size24.Folder())" Style="opacity:0.3;" />
        <div style="margin-top:16px;font-size:15px;">@L["explorer.empty"]</div>
    </div>
}
else
{
    @foreach (var sect in _sections)
    {
        var children = _children.GetValueOrDefault(sect.Id, []);
        var expanded = _expanded.Contains(sect.Id);

        <div style="border:1px solid var(--neutral-stroke-rest);border-radius:8px;margin-bottom:10px;overflow:hidden;">

            <!-- Section header -->
            <div style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:var(--neutral-layer-2);cursor:pointer;user-select:none;"
                 @onclick="@(() => ToggleExpand(sect.Id))">

                @if (expanded)
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" Style="flex-shrink:0;" />
                }
                else
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Style="flex-shrink:0;" />
                }
                <FluentIcon Value="@(new Icons.Regular.Size20.Folder())" Style="flex-shrink:0;" />

                <span style="font-weight:600;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@sect.Label</span>

                <span style="font-size:11px;color:var(--neutral-foreground-hint);max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex-shrink:1;">
                    @sect.Path
                </span>

                <FluentBadge Appearance="Appearance.Accent" Style="flex-shrink:0;font-size:11px;">
                    @(sect.FolderType switch {
                        FolderType.Series => L["folders.type_series"],
                        FolderType.Movie  => L["folders.type_movie"],
                        _                 => L["folders.type_auto"],
                    })
                </FluentBadge>

                <FluentBadge Appearance="Appearance.Neutral" Style="flex-shrink:0;font-size:11px;">
                    @children.Count
                </FluentBadge>

                <div @onclick:stopPropagation style="display:flex;align-items:center;gap:4px;flex-shrink:0;">
                    <FluentSwitch Value="@sect.WatchEnabled"
                                  ValueChanged="@(async (bool v) => await ToggleWatcher(sect, v))"
                                  Title="@L["explorer.tooltip_monitor"]"
                                  Style="min-width:unset;" />

                    <FluentButton IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                                  Title="@L["explorer.btn_refresh_tooltip"]"
                                  OnClick="@(() => RefreshSection(sect))" />
                    <FluentButton IconStart="@(new Icons.Regular.Size20.Edit())"
                                  Title="@L["folders.btn_edit"]"
                                  OnClick="@(() => OpenSectionDialog(sect))" />
                    <FluentButton Appearance="Appearance.Stealth"
                                  IconStart="@(new Icons.Regular.Size20.Delete())"
                                  Title="@L["folders.btn_delete"]"
                                  OnClick="@(() => AskDelete(sect, true))" />
                </div>
            </div>

            <!-- Subfolder rows -->
            @if (expanded)
            {
                @if (children.Count == 0)
                {
                    <div style="padding:10px 14px 10px 52px;font-size:13px;color:var(--neutral-foreground-hint);">
                        @L["explorer.subfolder_empty"]
                    </div>
                }
                else
                {
                    @foreach (var child in children.OrderBy(c => c.Label))
                    {
                        var filesOpen = _openFiles.Contains(child.Id);
                        <div>
                            <div style="display:flex;align-items:center;gap:8px;padding:8px 14px 8px 48px;border-top:1px solid var(--neutral-stroke-subtle);cursor:pointer;user-select:none;"
                                 @onclick="@(() => ToggleFilesOpen(child))">
                                <FluentIcon Value="@(filesOpen ? (Icon)(new Icons.Regular.Size16.ChevronDown()) : new Icons.Regular.Size16.ChevronRight())" Style="flex-shrink:0;opacity:0.7;" />
                                <FluentIcon Value="@(filesOpen ? (Icon)(new Icons.Regular.Size20.FolderOpen()) : new Icons.Regular.Size20.Folder())" Style="flex-shrink:0;opacity:0.7;" />
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@child.Label</div>
                                    <div style="font-size:11px;color:var(--neutral-foreground-hint);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@child.Path</div>
                                </div>
                                <FluentBadge Appearance="Appearance.Neutral" Style="flex-shrink:0;font-size:11px;">
                                    @(child.FolderType switch {
                                        FolderType.Series => L["folders.type_series"],
                                        FolderType.Movie  => L["folders.type_movie"],
                                        _                 => L["folders.type_auto"],
                                    })
                                </FluentBadge>
                                <div @onclick:stopPropagation style="display:flex;align-items:center;gap:4px;flex-shrink:0;">
                                    <FluentSwitch Value="@child.WatchEnabled"
                                                  ValueChanged="@(async (bool v) => await ToggleWatcher(child, v))"
                                                  Title="@L["explorer.tooltip_monitor"]"
                                                  Style="min-width:unset;" />
                                    <FluentButton IconStart="@(new Icons.Regular.Size20.Edit())"
                                                  Title="@L["folders.btn_edit"]"
                                                  OnClick="@(() => OpenEditPanel(child))" />
                                    <FluentButton Appearance="Appearance.Stealth"
                                                  IconStart="@(new Icons.Regular.Size20.Delete())"
                                                  Title="@L["folders.btn_delete"]"
                                                  OnClick="@(() => AskDelete(child, false))" />
                                </div>
                            </div>
                            @if (filesOpen)
                            {
                                @FileScanPanel(child.Id)
                            }
                        </div>
                    }
                }
            }

        </div>
    }

    @if (_standalone.Count > 0)
    {
        <FluentLabel Typo="Typography.H5" Style="margin:20px 0 10px;">@L["explorer.standalone_title"]</FluentLabel>
        <div style="border:1px solid var(--neutral-stroke-rest);border-radius:8px;overflow:hidden;">
            @foreach (var folder in _standalone)
            {
                var folderFilesOpen = _openFiles.Contains(folder.Id);
                <div>
                    <div style="display:flex;align-items:center;gap:8px;padding:10px 14px;border-bottom:1px solid var(--neutral-stroke-subtle);cursor:pointer;user-select:none;"
                         @onclick="@(() => ToggleFilesOpen(folder))">
                        <FluentIcon Value="@(folderFilesOpen ? (Icon)(new Icons.Regular.Size16.ChevronDown()) : new Icons.Regular.Size16.ChevronRight())" Style="flex-shrink:0;" />
                        <FluentIcon Value="@(folderFilesOpen ? (Icon)(new Icons.Regular.Size20.FolderOpen()) : new Icons.Regular.Size20.Folder())" Style="flex-shrink:0;" />
                        <div style="flex:1;min-width:0;">
                            <div style="font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@folder.Label</div>
                            <div style="font-size:11px;color:var(--neutral-foreground-hint);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@folder.Path</div>
                        </div>
                        <FluentBadge Appearance="Appearance.Neutral" Style="flex-shrink:0;font-size:11px;">
                            @(folder.FolderType switch {
                                FolderType.Series => L["folders.type_series"],
                                FolderType.Movie  => L["folders.type_movie"],
                                _                 => L["folders.type_auto"],
                            })
                        </FluentBadge>
                        <div @onclick:stopPropagation style="display:flex;align-items:center;gap:4px;flex-shrink:0;">
                            <FluentSwitch Value="@folder.WatchEnabled"
                                          ValueChanged="@(async (bool v) => await ToggleWatcher(folder, v))"
                                          Title="@L["explorer.tooltip_monitor"]"
                                          Style="min-width:unset;" />
                            <FluentButton IconStart="@(new Icons.Regular.Size20.Edit())"
                                          Title="@L["folders.btn_edit"]"
                                          OnClick="@(() => OpenEditPanel(folder))" />
                            <FluentButton Appearance="Appearance.Stealth"
                                          IconStart="@(new Icons.Regular.Size20.Delete())"
                                          Title="@L["folders.btn_delete"]"
                                          OnClick="@(() => AskDelete(folder, false))" />
                        </div>
                    </div>
                    @if (folderFilesOpen)
                    {
                        @FileScanPanel(folder.Id)
                    }
                </div>
            }
        </div>
    }
}

<!-- ================================================================ -->
<!-- ADD / EDIT SECTION DIALOG -->
<!-- ================================================================ -->
<FluentDialog @bind-Hidden="_sectionDialogHidden" Modal="true" TrapFocus="true" PreventScroll="true" Width="500px">
    <FluentDialogHeader ShowDismiss="true">
        <FluentLabel Typo="Typography.H6">
            @(_sectionEditTarget is null ? L["explorer.dialog_add_title"] : L["explorer.dialog_edit_title"])
        </FluentLabel>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Style="gap:14px;">
            @if (!_pickerMode)
            {
                <div style="display:flex;align-items:flex-end;gap:6px;">
                    <FluentTextField @bind-Value="_formPath"
                                     Label="@(L["folders.field_path_label"])"
                                     Placeholder="@(L["folders.field_path_placeholder"])"
                                     style="flex:1;" />
                    <FluentButton Appearance="Appearance.Outline"
                                  IconStart="@(new Icons.Regular.Size20.FolderOpen())"
                                  Title="@(L["explorer.picker_browse"])"
                                  OnClick="OpenPicker" />
                </div>
            }
            else
            {
                <div>
                    <FluentLabel Style="font-size:13px;font-weight:600;margin-bottom:8px;display:block;">@L["explorer.picker_title"]</FluentLabel>

                    @if (_pickerCurrent is null)
                    {
                        <!-- Drive list -->
                        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
                            @foreach (var drive in _drives)
                            {
                                <FluentButton Appearance="Appearance.Outline"
                                              IconStart="@(new Icons.Regular.Size20.HardDrive())"
                                              OnClick="@(() => PickerSelectDrive(drive.RootDirectory.FullName))">
                                    @drive.Name
                                </FluentButton>
                            }
                        </div>
                    }
                    else
                    {
                        <!-- Breadcrumb + Up button -->
                        <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;min-width:0;">
                            <FluentButton Appearance="Appearance.Stealth"
                                          IconStart="@(new Icons.Regular.Size20.ArrowUp())"
                                          OnClick="PickerNavigateUp"
                                          Title="@(L["explorer.picker_up"])" />
                            <span style="font-size:12px;color:var(--neutral-foreground-hint);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;"
                                  title="@_pickerCurrent">@_pickerCurrent</span>
                        </div>

                        <!-- Subdirectory list -->
                        <div style="max-height:180px;overflow-y:auto;border:1px solid var(--neutral-stroke-rest);border-radius:4px;">
                            @if (_pickerChildren.Count == 0)
                            {
                                <div style="padding:10px;font-size:12px;color:var(--neutral-foreground-hint);">@L["explorer.picker_empty"]</div>
                            }
                            else
                            {
                                @foreach (var dir in _pickerChildren)
                                {
                                    <div style="display:flex;align-items:center;gap:6px;padding:5px 10px;cursor:pointer;border-bottom:1px solid var(--neutral-stroke-subtle);"
                                         @onclick="@(() => PickerNavigateInto(dir))">
                                        <FluentIcon Value="@(new Icons.Regular.Size16.Folder())" />
                                        <span style="font-size:13px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@Path.GetFileName(dir)</span>
                                    </div>
                                }
                            }
                        </div>

                        <!-- Confirm current dir -->
                        <div style="display:flex;justify-content:flex-end;margin-top:8px;gap:6px;">
                            <span style="font-size:12px;color:var(--neutral-foreground-hint);align-self:center;overflow:hidden;text-overflow:ellipsis;max-width:250px;" title="@_pickerCurrent">
                                @L["explorer.picker_selected"] <b>@Path.GetFileName(_pickerCurrent)</b>
                            </span>
                            <FluentButton Appearance="Appearance.Accent" OnClick="PickerConfirm">@L["explorer.picker_select_btn"]</FluentButton>
                            <FluentButton OnClick="@(() => _pickerMode = false)">@L["folders.btn_cancel"]</FluentButton>
                        </div>
                    }
                </div>
            }
            <FluentTextField @bind-Value="_formLabel"
                             Label="@(L["folders.field_name_label"])"
                             Placeholder="@(L["folders.field_name_placeholder"])"
                             style="width:100%;" />
            <FluentSwitch @bind-Value="_formWatch">@L["folders.switch_monitor"]</FluentSwitch>
            <FluentSwitch @bind-Value="_formRenameEnabled">@L["folders.switch_rename"]</FluentSwitch>
            @if (_formRenameEnabled)
            {
                <FluentSelect TOption="string" @bind-Value="_formFolderTypeStr"
                              Label="@(L["folders.content_type_label"])" style="width:100%;">
                    <FluentOption TOption="string" Value="Auto">@L["folders.content_type_auto"]</FluentOption>
                    <FluentOption TOption="string" Value="Series">@L["folders.content_type_series"]</FluentOption>
                    <FluentOption TOption="string" Value="Movie">@L["folders.content_type_movie"]</FluentOption>
                </FluentSelect>
            }
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="SaveSection"
                      Disabled="@(string.IsNullOrWhiteSpace(_formPath) || string.IsNullOrWhiteSpace(_formLabel))">
            @L["folders.btn_save"]
        </FluentButton>
        <FluentButton OnClick="@(() => _sectionDialogHidden = true)">@L["folders.btn_cancel"]</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

<!-- ================================================================ -->
<!-- DELETE CONFIRMATION -->
<!-- ================================================================ -->
<FluentDialog @bind-Hidden="_deleteHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader ShowDismiss="true">
        <FluentLabel Typo="Typography.H6">@L["folders.delete_title"]</FluentLabel>
    </FluentDialogHeader>
    <FluentDialogBody>
        @if (_deleteIsSection)
        {
            <FluentLabel>@L.Get("explorer.delete_section_body", _deleteTarget?.Label)</FluentLabel>
        }
        else
        {
            <FluentLabel>@L.Get("folders.delete_body", _deleteTarget?.Label)</FluentLabel>
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmDelete">@L["folders.btn_delete_confirm"]</FluentButton>
        <FluentButton OnClick="@(() => _deleteHidden = true)">@L["folders.btn_cancel"]</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

<!-- ================================================================ -->
<!-- EDIT FOLDER PANEL -->
<!-- ================================================================ -->
@if (!_editPanelHidden)
{
    <div style="position:fixed;inset:0;background:rgba(0,0,0,0.25);z-index:999;" @onclick="@(() => _editPanelHidden = true)"></div>
    <div style="position:fixed;top:0;right:0;width:640px;height:100vh;background:var(--neutral-layer-floating);border-left:1px solid var(--neutral-stroke-rest);box-shadow:-4px 0 16px rgba(0,0,0,.15);z-index:1000;overflow-y:auto;overflow-x:hidden;padding:20px;box-sizing:border-box;" @onclick:stopPropagation>

        <div style="display:flex;align-items:center;margin-bottom:16px;gap:8px;">
            <FluentLabel Typo="Typography.H4" Style="flex:1;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@(_editTarget?.Label ?? "")</FluentLabel>
            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.Dismiss())" Title="@(L["folders.btn_cancel"])" OnClick="@(() => _editPanelHidden = true)" />
        </div>

        <div style="display:flex;flex-direction:column;gap:16px;">

            <!-- Basic settings -->
            <div style="padding:14px;background:var(--neutral-layer-2);border-radius:6px;display:flex;flex-direction:column;gap:12px;width:100%;box-sizing:border-box;">
                <FluentTextField @bind-Value="_editLabel"
                                 Label="@(L["folders.field_name_label"])"
                                 style="width:100%;" />
                <FluentSwitch @bind-Value="_editWatch">@L["folders.switch_monitor"]</FluentSwitch>
                <FluentSwitch @bind-Value="_editRenameEnabled">@L["folders.switch_rename"]</FluentSwitch>
                @if (_editRenameEnabled)
                {
                    <FluentSelect TOption="string" @bind-Value="_editFolderTypeStr"
                                  Label="@(L["folders.content_type_label"])" style="width:100%;">
                        <FluentOption TOption="string" Value="Auto">@L["folders.content_type_auto"]</FluentOption>
                        <FluentOption TOption="string" Value="Series">@L["folders.content_type_series"]</FluentOption>
                        <FluentOption TOption="string" Value="Movie">@L["folders.content_type_movie"]</FluentOption>
                    </FluentSelect>
                }
                <FluentButton Appearance="Appearance.Accent" OnClick="SaveEditFolder"
                              Disabled="@string.IsNullOrWhiteSpace(_editLabel)">
                    @L["folders.btn_save"]
                </FluentButton>
            </div>

            <!-- Inherited (global) patterns -->
            <FluentDivider />
            <FluentLabel Typo="Typography.H3" Style="margin-bottom:2px;">@L["folder_detail.inherited_patterns_title"]</FluentLabel>
            <FluentLabel Style="font-size:13px;color:var(--neutral-foreground-hint);margin-bottom:4px;">@L["folder_detail.inherited_patterns_hint"]</FluentLabel>

            @if (_inheritedPatterns.Count == 0)
            {
                <FluentLabel Style="color:var(--neutral-foreground-hint);">@L["folder_detail.inherited_patterns_empty"]</FluentLabel>
            }
            else
            {
                <FluentDataGrid Items="@_inheritedPatterns.AsQueryable()" TGridItem="RenamePattern" ShowHover="true">
                    <TemplateColumn Title="@(L["patterns.col_priority"])" Width="60px" Align="Align.Center">
                        <span style="opacity:@(_disabledInheritedPatternIds.Contains(context.Id) ? 0.4 : 1.0);">@context.Priority</span>
                    </TemplateColumn>
                    <TemplateColumn Title="@(L["patterns.col_name"])">
                        <span style="opacity:@(_disabledInheritedPatternIds.Contains(context.Id) ? 0.4 : 1.0);">@context.Name</span>
                    </TemplateColumn>
                    <TemplateColumn Title="" Align="Align.End" Width="120px">
                        @{var isDisabled = _disabledInheritedPatternIds.Contains(context.Id);}
                        <FluentSwitch Value="@(!isDisabled)"
                                      ValueChanged="@(async (bool v) => await ToggleInheritedPatternAsync(context, !v))"
                                      Title="@(isDisabled ? L["folder_detail.inherited_pattern_disabled"] : L["folder_detail.inherited_pattern_active"])" />
                    </TemplateColumn>
                </FluentDataGrid>
            }

            <!-- Folder-specific patterns -->
            <FluentDivider />
            <div style="display:flex;align-items:center;gap:8px;">
                <FluentLabel Typo="Typography.H3" Style="flex:1;margin:0;">@L["folder_detail.override_patterns_title"]</FluentLabel>
                <FluentButton Appearance="Appearance.Accent"
                              IconStart="@(new Icons.Regular.Size20.Add())"
                              OnClick="@(() => OpenEditPatternDialog(null))">
                    @L["patterns.add_button"]
                </FluentButton>
            </div>
            <FluentLabel Style="font-size:13px;color:var(--neutral-foreground-hint);">@L["folder_detail.patterns_hint"]</FluentLabel>

            @if (_editPatterns.Count == 0)
            {
                <FluentLabel Style="color:var(--neutral-foreground-hint);">@L["folder_detail.patterns_empty"]</FluentLabel>
            }
            else
            {
                <FluentDataGrid Items="@_editPatterns.AsQueryable()" TGridItem="RenamePattern" ShowHover="true">
                    <TemplateColumn Title="@(L["patterns.col_priority"])" Width="60px" Align="Align.Center">
                        @context.Priority
                    </TemplateColumn>
                    <PropertyColumn Property="@(p => p.Name)" Title="@(L["patterns.col_name"])" />
                    <TemplateColumn Title="@(L["patterns.col_regex"])">
                        <code style="font-size:11px;word-break:break-all;">@context.Pattern</code>
                    </TemplateColumn>
                    <TemplateColumn Title="" Align="Align.End" Width="110px">
                        <FluentButton IconStart="@(new Icons.Regular.Size20.Edit())"
                                      OnClick="@(() => OpenEditPatternDialog(context))">
                            @L["patterns.btn_edit"]
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth"
                                      IconStart="@(new Icons.Regular.Size20.Delete())"
                                      OnClick="@(() => DeleteEditPatternAsync(context))">
                            @L["patterns.btn_delete"]
                        </FluentButton>
                    </TemplateColumn>
                </FluentDataGrid>
            }

            <!-- Pattern tester -->
            <FluentDivider Style="margin:4px 0;" />
            <FluentLabel Typo="Typography.H3" Style="margin-bottom:4px;">@L["patterns.test_title"]</FluentLabel>
            <FluentLabel Style="font-size:13px;color:var(--neutral-foreground-hint);">@L["folder_detail.test_hint"]</FluentLabel>
            <div style="display:flex;align-items:flex-end;gap:10px;">
                <FluentTextField @bind-Value="_editTestInput"
                                 Label="@(L["patterns.test_field_label"])"
                                 Placeholder="@(L["patterns.test_placeholder"])"
                                 style="flex:1;" />
                <FluentButton Appearance="Appearance.Accent" OnClick="TestEditPattern">@L["patterns.test_button"]</FluentButton>
            </div>
            @if (_editTestResult is not null)
            {
                <div style="padding:12px;background:var(--neutral-layer-2);border-radius:6px;">
                    @if (_editTestResult.IsMatched)
                    {
                        <div style="color:#107c10;font-weight:600;margin-bottom:6px;">@L["patterns.test_matched"]</div>
                        <div style="font-family:monospace;font-size:13px;line-height:1.8;">
                            @L["patterns.test_season_label"] <b>@(_editTestResult.Season?.ToString() ?? L["patterns.test_season_not_found"])</b><br />
                            @L["patterns.test_episode_label"] <b>@_editTestResult.Episode</b><br />
                            @L["patterns.test_kind_label"] <b>@_editTestKind</b><br />
                            @L["patterns.test_new_name_label"] <b style="color:#107c10;">@(_editTestNewName ?? "—")</b>
                        </div>
                    }
                    else
                    {
                        <div style="color:#a80000;font-weight:600;">@L["patterns.test_not_matched"]</div>
                    }
                </div>
            }

            <!-- Ignore rules -->
            <FluentDivider />
            <FluentLabel Typo="Typography.H3" Style="margin-bottom:4px;">@L["folder_detail.rules_title"]</FluentLabel>
            <FluentLabel Style="font-size:13px;color:var(--neutral-foreground-hint);">@L["folder_detail.rules_hint"]</FluentLabel>
            <div style="display:flex;align-items:flex-end;gap:8px;">
                <FluentTextField @bind-Value="_editNewMask"
                                 Placeholder="@(L["settings.new_mask_placeholder"])"
                                 Label="@(L["settings.new_mask_label"])"
                                 style="flex:1;" />
                <FluentButton Appearance="Appearance.Accent"
                              IconStart="@(new Icons.Regular.Size20.Add())"
                              OnClick="AddEditRuleAsync"
                              Disabled="@string.IsNullOrWhiteSpace(_editNewMask)">
                    @L["settings.btn_add_mask"]
                </FluentButton>
            </div>
            @if (_editRules.Count == 0)
            {
                <FluentLabel Style="color:var(--neutral-foreground-hint);">@L["folder_detail.rules_empty"]</FluentLabel>
            }
            else
            {
                <FluentDataGrid Items="@_editRules.AsQueryable()" TGridItem="IgnoreRule" ShowHover="true">
                    <PropertyColumn Property="@(r => r.Mask)" Title="@(L["settings.col_mask"])" />
                    <TemplateColumn Title="" Align="Align.End" Width="100px">
                        <FluentButton Appearance="Appearance.Stealth"
                                      IconStart="@(new Icons.Regular.Size20.Delete())"
                                      OnClick="@(() => DeleteEditRuleAsync(context))">
                            @L["settings.btn_delete_mask"]
                        </FluentButton>
                    </TemplateColumn>
                </FluentDataGrid>
            }

        </div>
    </div>
}

<!-- ================================================================ -->
<!-- PATTERN ADD/EDIT DIALOG (inside edit panel) -->
<!-- ================================================================ -->
<FluentDialog @bind-Hidden="_editPatternDialogHidden" Modal="true" TrapFocus="true" PreventScroll="true" Width="540px">
    <FluentDialogHeader ShowDismiss="true">
        <FluentLabel Typo="Typography.H4">
            @(_editPatternTarget is null ? L["patterns.dialog_add_title"] : L["patterns.dialog_edit_title"])
        </FluentLabel>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Style="gap:14px;">
            <FluentTextField @bind-Value="_editPatternName"
                             Label="@(L["patterns.field_name_label"])"
                             Placeholder="@(L["patterns.field_name_placeholder"])"
                             style="width:100%;" />
            <FluentTextField @bind-Value="_editPatternRegex"
                             Label="@(L["patterns.field_regex_label"])"
                             Placeholder="@(L["patterns.field_regex_placeholder"])"
                             style="width:100%;font-family:monospace;" />
            <FluentNumberField TValue="int" @bind-Value="_editPatternPriority"
                               Label="@(L["patterns.field_priority_label"])"
                               Min="1" Max="999" style="width:160px;" />
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="SaveEditPatternAsync"
                      Disabled="@(string.IsNullOrWhiteSpace(_editPatternName) || string.IsNullOrWhiteSpace(_editPatternRegex))">
            @L["patterns.btn_save"]
        </FluentButton>
        <FluentButton OnClick="@(() => _editPatternDialogHidden = true)">@L["patterns.btn_cancel"]</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private List<FolderWatcher> _sections = [];
    private Dictionary<Guid, List<FolderWatcher>> _children = [];
    private List<FolderWatcher> _standalone = [];
    private bool _loading = true;
    private HashSet<Guid> _expanded = [];

    // ── Section add/edit dialog ────────────────────────────────────
    private bool _sectionDialogHidden = true;
    private FolderWatcher? _sectionEditTarget;
    private string _formPath = "";
    private string _formLabel = "";
    private bool _formWatch = true;
    private bool _formRenameEnabled = true;
    private string _formFolderTypeStr = "Auto";

    // Folder picker (embedded in add dialog)
    private List<DriveInfo> _drives = [];
    private string? _pickerCurrent;
    private List<string> _pickerChildren = [];
    private bool _pickerMode = false;

    // ── Inline file scan ───────────────────────────────────────────
    private HashSet<Guid> _openFiles = [];
    private Dictionary<Guid, List<RenamePreviewItem>?> _previews = new();
    private HashSet<Guid> _scanBusy = [];
    private HashSet<Guid> _applyBusy = [];
    private Dictionary<Guid, List<(string From, string To)>> _autoRenameEvents = new();
    private Dictionary<Guid, string> _folderPaths = new();
    private Dictionary<string, bool> _expandedScanNodes = new();

    // ── Edit folder panel ──────────────────────────────────────────
    private bool _editPanelHidden = true;
    private FolderWatcher? _editTarget;
    private string _editLabel = "";
    private bool _editWatch = true;
    private bool _editRenameEnabled = true;
    private string _editFolderTypeStr = "Auto";

    // Edit panel – patterns
    private List<RenamePattern> _editPatterns = [];
    private List<RenamePattern> _inheritedPatterns = [];
    private HashSet<Guid> _disabledInheritedPatternIds = [];
    private bool _editPatternDialogHidden = true;
    private RenamePattern? _editPatternTarget;
    private string _editPatternName = "";
    private string _editPatternRegex = "";
    private int _editPatternPriority = 100;
    private string _editTestInput = "";
    private ParseResult? _editTestResult;
    private string? _editTestNewName;
    private string _editTestKind = "";

    // Edit panel – ignore rules
    private List<IgnoreRule> _editRules = [];
    private string _editNewMask = "";

    // ── Delete dialog ──────────────────────────────────────────────
    private bool _deleteHidden = true;
    private FolderWatcher? _deleteTarget;
    private bool _deleteIsSection;

    // ── Init ───────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        foreach (var s in _sections.Where(s => _children.ContainsKey(s.Id)))
            _expanded.Add(s.Id);
        _loading = false;
        WatcherService.FileRenamed += OnFileRenamed;
    }

    public void Dispose() => WatcherService.FileRenamed -= OnFileRenamed;

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var all = await db.FolderWatchers.OrderBy(f => f.Label).ToListAsync();
        _sections  = all.Where(f => f.IsSection).ToList();
        _children  = all
            .Where(f => !f.IsSection && f.ParentSectionId.HasValue)
            .GroupBy(f => f.ParentSectionId!.Value)
            .ToDictionary(g => g.Key, g => g.ToList());
        _standalone = all.Where(f => !f.IsSection && !f.ParentSectionId.HasValue).ToList();
        _folderPaths = all.ToDictionary(f => f.Id, f => f.Path);
    }

    private void ToggleExpand(Guid id)
    {
        if (!_expanded.Remove(id)) _expanded.Add(id);
    }

    // ── Inline file scan ───────────────────────────────────────────

    private async Task ToggleFilesOpen(FolderWatcher folder)
    {
        if (_openFiles.Contains(folder.Id))
        {
            _openFiles.Remove(folder.Id);
        }
        else
        {
            _openFiles.Add(folder.Id);
            if (!_previews.ContainsKey(folder.Id))
                await ScanFolderAsync(folder.Id);
        }
    }

    private async Task ScanFolderAsync(Guid folderId)
    {
        _scanBusy.Add(folderId);
        _previews[folderId] = null;
        StateHasChanged();
        try
        {
            _previews[folderId] = await RenameService.ScanFolderAsync(folderId);
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(ToastIntent.Error, L.Get("folder_files.toast_scan_error", ex.Message));
        }
        finally
        {
            _scanBusy.Remove(folderId);
            StateHasChanged();
        }
    }

    private async Task ApplyFolderAsync(Guid folderId)
    {
        if (!_previews.TryGetValue(folderId, out var items) || items is null) return;
        _applyBusy.Add(folderId);
        StateHasChanged();
        try
        {
            var approved = items.Where(i => i.IsSelected && i.Status == PreviewStatus.WillRename).ToList();
            await RenameService.ApplyRenamesAsync(folderId, approved);
            ToastService.ShowToast(ToastIntent.Success, L.Get("folder_files.toast_renamed", approved.Count));
            _previews[folderId] = null;
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(ToastIntent.Error, L.Get("folder_files.toast_error", ex.Message));
        }
        finally
        {
            _applyBusy.Remove(folderId);
            StateHasChanged();
        }
    }

    private void FolderSelectToggle(Guid folderId, bool selectAll)
    {
        if (!_previews.TryGetValue(folderId, out var items) || items is null) return;
        items.Where(i => i.Status == PreviewStatus.WillRename).ToList().ForEach(i => i.IsSelected = selectAll);
    }

    private void OnFileRenamed(Guid folderId, string from, string to)
    {
        if (!_openFiles.Contains(folderId)) return;
        if (!_autoRenameEvents.ContainsKey(folderId))
            _autoRenameEvents[folderId] = [];
        var events = _autoRenameEvents[folderId];
        events.Insert(0, (from, to));
        if (events.Count > 15) events.RemoveAt(15);
        InvokeAsync(StateHasChanged);
    }

    private RenderFragment FileScanPanel(Guid fId) => __builder =>
    {
        var scanning = _scanBusy.Contains(fId);
        var applying = _applyBusy.Contains(fId);
        _previews.TryGetValue(fId, out var items);
        var renameable = items?.Where(i => i.Status == PreviewStatus.WillRename).ToList();
        var selected   = renameable?.Count(i => i.IsSelected) ?? 0;
        var allSelected = renameable is { Count: > 0 } && renameable.All(i => i.IsSelected);
        var someSelected = selected > 0 && !allSelected;
        _autoRenameEvents.TryGetValue(fId, out var autoEvents);

        <div style="padding:12px 14px 14px 48px;background:var(--neutral-layer-3);border-top:1px solid var(--neutral-stroke-subtle);">
            <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap:8px;flex-wrap:wrap;margin-bottom:8px;">
                <FluentButton Appearance="Appearance.Accent"
                              IconStart="@(new Icons.Regular.Size20.Search())"
                              OnClick="@(() => ScanFolderAsync(fId))"
                              Disabled="@scanning">
                    @(scanning ? L["folder_files.btn_scanning"] : L["folder_files.btn_scan"])
                </FluentButton>
                @if (items is not null)
                {
                    <div style="display:flex;align-items:center;gap:6px;flex:1;">
                        <FluentCheckbox Value="@allSelected"
                                        Indeterminate="@someSelected"
                                        ValueChanged="@((bool v) => FolderSelectToggle(fId, v || someSelected))"
                                        Title="@(allSelected ? L["folder_files.btn_deselect_all"] : L["folder_files.btn_select_all"])"
                                        Disabled="@(renameable is null || renameable.Count == 0)" />
                        <FluentLabel Style="font-size:12px;">
                            @L.Get("folder_files.stats", items.Count, renameable?.Count ?? 0, selected)
                        </FluentLabel>
                    </div>
                    <FluentButton Appearance="Appearance.Accent"
                                  IconStart="@(new Icons.Regular.Size20.Checkmark())"
                                  OnClick="@(() => ApplyFolderAsync(fId))"
                                  Disabled="@(selected == 0 || applying)">
                        @(applying ? L["folder_files.btn_applying"] : L.Get("folder_files.btn_apply", selected))
                    </FluentButton>
                }
            </FluentStack>

            @if (scanning)
            {
                <progress style="width:100%;height:4px;margin-bottom:8px;"></progress>
            }

            @if (items is { Count: > 0 })
            {
                var tree = BuildScanTree(fId, items);
                <div style="border:1px solid var(--neutral-stroke-subtle);border-radius:4px;overflow:hidden;">
                    <!-- header row -->
                    <div style="display:grid;grid-template-columns:44px 1fr 28px 1fr 140px 1fr;background:var(--neutral-layer-2);border-bottom:1px solid var(--neutral-stroke-subtle);font-size:12px;font-weight:600;color:var(--neutral-foreground-rest);">
                        <div></div>
                        <div style="padding:5px 4px;">@L["folder_files.col_original"]</div>
                        <div></div>
                        <div style="padding:5px 4px;">@L["folder_files.col_new"]</div>
                        <div style="padding:5px 4px;">@L["folder_files.col_status"]</div>
                        <div style="padding:5px 4px;">@L["folder_files.col_reason"]</div>
                    </div>
                    @RenderScanNodes(fId, tree.Children, 0)
                </div>
            }
            else if (items is not null && !scanning)
            {
                <div style="font-size:13px;color:var(--neutral-foreground-hint);padding:6px 0;">
                    @L["folder_files.status_already_correct"]
                </div>
            }

            @if (autoEvents is { Count: > 0 })
            {
                <FluentDivider Style="margin:12px 0 8px;" />
                <FluentLabel Typo="Typography.H3" Style="margin-bottom:8px;">
                    @L.Get("folder_files.auto_rename_section", autoEvents.Count)
                </FluentLabel>
                @foreach (var ev in autoEvents)
                {
                    <div style="font-family:monospace;font-size:13px;margin:3px 0;">
                        <span style="color:var(--neutral-foreground-hint);">@ev.From</span>
                        &nbsp;→&nbsp;
                        <span style="color:#107c10;">@ev.To</span>
                    </div>
                }
            }
        </div>
    };

    // ── Scan tree ──────────────────────────────────────────────────

    private class ScanNode
    {
        public string Name { get; set; } = "";
        public string RelPath { get; set; } = "";
        public bool IsDir { get; set; }
        public RenamePreviewItem? Item { get; set; }
        public List<ScanNode> Children { get; } = [];
        public int FileCount => IsDir ? Children.Sum(c => c.IsDir ? c.FileCount : 1) : 0;
    }

    private ScanNode BuildScanTree(Guid fId, List<RenamePreviewItem> items)
    {
        var root = new ScanNode { IsDir = true };
        _folderPaths.TryGetValue(fId, out var baseDir);
        baseDir ??= "";

        foreach (var item in items)
        {
            string relPath;
            try { relPath = Path.GetRelativePath(baseDir, item.OriginalPath); }
            catch { relPath = Path.GetFileName(item.OriginalPath); }

            var parts = relPath.Split(
                new[] { Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar },
                StringSplitOptions.RemoveEmptyEntries);
            InsertScanNode(root, parts, 0, item, "");
        }
        return root;
    }

    private static void InsertScanNode(ScanNode parent, string[] parts, int idx, RenamePreviewItem item, string relBase)
    {
        if (idx >= parts.Length) return;
        var name = parts[idx];
        var rel = relBase.Length > 0 ? relBase + "/" + name : name;

        if (idx == parts.Length - 1)
        {
            parent.Children.Add(new ScanNode { Name = name, RelPath = rel, IsDir = false, Item = item });
            return;
        }

        var dir = parent.Children.FirstOrDefault(c => c.IsDir && c.Name == name);
        if (dir == null)
        {
            dir = new ScanNode { Name = name, RelPath = rel, IsDir = true };
            parent.Children.Add(dir);
        }
        InsertScanNode(dir, parts, idx + 1, item, rel);
    }

    private RenderFragment RenderScanNodes(Guid fId, List<ScanNode> nodes, int depth) => __builder =>
    {
        // Folders first (natural order), then files (natural order)
        var sorted = nodes
            .OrderByDescending(n => n.IsDir)
            .ThenBy(n => n.Name, NaturalStringComparer.Ordinal);
        foreach (var node in sorted)
        {
            if (node.IsDir)
            {
                var key = $"{fId}|{node.RelPath}";
                var exp = _expandedScanNodes.GetValueOrDefault(key, false);
                var capturedKey = key;
                var fc = node.FileCount;
                <div style="display:flex;align-items:center;gap:6px;padding:5px 8px 5px @(depth * 16 + 8)px;background:var(--neutral-layer-2);cursor:pointer;border-bottom:1px solid var(--neutral-stroke-subtle);user-select:none;"
                     @onclick="@(() => { _expandedScanNodes[capturedKey] = !_expandedScanNodes.GetValueOrDefault(capturedKey, false); })">
                    <FluentIcon Value="@(exp ? (Icon)(new Icons.Regular.Size16.ChevronDown()) : new Icons.Regular.Size16.ChevronRight())" Style="flex-shrink:0;opacity:0.7;" />
                    <FluentIcon Value="@(exp ? (Icon)(new Icons.Regular.Size16.FolderOpen()) : new Icons.Regular.Size16.Folder())" Style="flex-shrink:0;opacity:0.7;" />
                    <span style="font-size:13px;font-weight:500;">@node.Name</span>
                    <span style="font-size:12px;color:var(--neutral-foreground-hint);">(@fc)</span>
                </div>
                @if (exp)
                {
                    @RenderScanNodes(fId, node.Children, depth + 1)
                }
            }
            else if (node.Item is { } item)
            {
                <div style="display:grid;grid-template-columns:44px 1fr 28px 1fr 140px 1fr;border-bottom:1px solid var(--neutral-stroke-subtle);align-items:center;">
                    <div style="padding:4px 8px;display:flex;align-items:center;">
                        <FluentCheckbox Value="@item.IsSelected"
                                        ValueChanged="@((bool v) => item.IsSelected = v)"
                                        Disabled="@(item.Status != PreviewStatus.WillRename)" />
                    </div>
                    <div style="padding:4px 4px 4px @(depth * 16 + 4)px;overflow:hidden;">
                        <code style="font-size:13px;opacity:@(item.Status == PreviewStatus.WillRename ? 1.0 : 0.5);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block;">@item.OriginalName</code>
                    </div>
                    <div style="padding:4px;text-align:center;">
                        @if (item.Status == PreviewStatus.WillRename)
                        {<span style="color:var(--neutral-foreground-hint);">→</span>}
                    </div>
                    <div style="padding:4px;overflow:hidden;">
                        @if (item.NewName is not null)
                        {<code style="font-size:13px;color:@GetNameColor(item.Status);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block;">@item.NewName</code>}
                    </div>
                    <div style="padding:4px;">
                        <span class="@GetStatusClass(item.Status)">@GetStatusLabel(item.Status)</span>
                    </div>
                    <div style="padding:4px;overflow:hidden;">
                        <span style="font-size:12px;color:var(--neutral-foreground-hint);">@item.Reason</span>
                    </div>
                </div>
            }
        }
    };

    private string GetStatusLabel(PreviewStatus s) => s switch
    {
        PreviewStatus.WillRename      => L["folder_files.status_will_rename"],
        PreviewStatus.WillSkip        => L["folder_files.status_will_skip"],
        PreviewStatus.AlreadyCorrect  => L["folder_files.status_already_correct"],
        PreviewStatus.Error           => L["folder_files.status_error"],
        _                             => "—"
    };

    private static string GetStatusClass(PreviewStatus s) => s switch
    {
        PreviewStatus.WillRename      => "status-badge status-pending",
        PreviewStatus.WillSkip        => "status-badge status-skipped",
        PreviewStatus.AlreadyCorrect  => "status-badge status-renamed",
        PreviewStatus.Error           => "status-badge status-error",
        _                             => "status-badge"
    };

    private static string GetNameColor(PreviewStatus s) => s switch
    {
        PreviewStatus.WillRename => "#107c10",
        PreviewStatus.Error      => "#a80000",
        _                        => "inherit"
    };

    // ── Edit folder panel ──────────────────────────────────────────

    private async Task OpenEditPanel(FolderWatcher folder)
    {
        _editTarget           = folder;
        _editLabel            = folder.Label;
        _editWatch            = folder.WatchEnabled;
        _editRenameEnabled    = folder.RenameEnabled;
        _editFolderTypeStr    = folder.FolderType.ToString();
        _editTestInput        = "";
        _editTestResult       = null;
        _editNewMask          = "";
        _editPatternDialogHidden = true;

        await using var db = await DbFactory.CreateDbContextAsync();
        _editPatterns = await db.RenamePatterns
            .Where(p => p.FolderId == folder.Id && p.Scope == PatternScope.FolderOverride && !p.IsExcluded)
            .OrderBy(p => p.Priority)
            .ToListAsync();
        _inheritedPatterns = await db.RenamePatterns
            .Where(p => p.Scope == PatternScope.Global)
            .OrderBy(p => p.Priority)
            .ToListAsync();
        _disabledInheritedPatternIds = (await db.RenamePatterns
            .Where(p => p.FolderId == folder.Id && p.IsExcluded && p.GlobalPatternId.HasValue)
            .Select(p => p.GlobalPatternId!.Value)
            .ToListAsync()).ToHashSet();
        _editRules = await db.IgnoreRules
            .Where(r => r.FolderId == folder.Id && r.Scope == RuleScope.FolderOverride)
            .OrderBy(r => r.Mask)
            .ToListAsync();

        _editPanelHidden = false;
    }

    private async Task SaveEditFolder()
    {
        if (_editTarget is null || string.IsNullOrWhiteSpace(_editLabel)) return;
        var folderType = Enum.TryParse<FolderType>(_editFolderTypeStr, out var ft) ? ft : FolderType.Auto;

        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.FolderWatchers.FindAsync(_editTarget.Id);
        if (entity is null) return;

        var wasEnabled = entity.WatchEnabled;
        entity.Label         = _editLabel.Trim();
        entity.WatchEnabled  = _editWatch;
        entity.RenameEnabled = _editRenameEnabled;
        entity.FolderType    = _editRenameEnabled ? folderType : FolderType.Auto;
        await db.SaveChangesAsync();

        if (!wasEnabled && _editWatch) await WatcherService.StartWatcherAsync(entity.Id);
        else if (wasEnabled && !_editWatch) await WatcherService.StopWatcherAsync(entity.Id);

        ToastService.ShowToast(ToastIntent.Success, L.Get("explorer.toast_folder_updated", entity.Label));
        _editPanelHidden = true;
        await LoadAsync();
    }

    // ── Edit panel – patterns ──────────────────────────────────────

    private void OpenEditPatternDialog(RenamePattern? p)
    {
        _editPatternTarget   = p;
        _editPatternName     = p?.Name ?? "";
        _editPatternRegex    = p?.Pattern ?? "";
        _editPatternPriority = p?.Priority ?? 100;
        _editPatternDialogHidden = false;
    }

    private async Task SaveEditPatternAsync()
    {
        if (_editTarget is null || string.IsNullOrWhiteSpace(_editPatternName) || string.IsNullOrWhiteSpace(_editPatternRegex)) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        if (_editPatternTarget is null)
        {
            db.RenamePatterns.Add(new RenamePattern
            {
                Id        = Guid.NewGuid(),
                Name      = _editPatternName.Trim(),
                Pattern   = _editPatternRegex.Trim(),
                Priority  = _editPatternPriority,
                Scope     = PatternScope.FolderOverride,
                FolderId  = _editTarget.Id,
                IsBuiltIn = false,
            });
            ToastService.ShowToast(ToastIntent.Success, L["patterns.toast_added"]);
        }
        else
        {
            var entity = await db.RenamePatterns.FindAsync(_editPatternTarget.Id);
            if (entity is null) return;
            entity.Name     = _editPatternName.Trim();
            entity.Pattern  = _editPatternRegex.Trim();
            entity.Priority = _editPatternPriority;
            ToastService.ShowToast(ToastIntent.Success, L["patterns.toast_updated"]);
        }
        await db.SaveChangesAsync();
        _editPatternDialogHidden = true;
        await ReloadEditPatternsAsync();
    }

    private async Task DeleteEditPatternAsync(RenamePattern p)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.RenamePatterns.FindAsync(p.Id);
        if (entity is not null) { db.RenamePatterns.Remove(entity); await db.SaveChangesAsync(); }
        ToastService.ShowToast(ToastIntent.Success, L.Get("patterns.toast_deleted", p.Name));
        await ReloadEditPatternsAsync();
    }

    private async Task ReloadEditPatternsAsync()
    {
        if (_editTarget is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        _editPatterns = await db.RenamePatterns
            .Where(p => p.FolderId == _editTarget.Id && p.Scope == PatternScope.FolderOverride && !p.IsExcluded)
            .OrderBy(p => p.Priority)
            .ToListAsync();
    }

    private async Task ToggleInheritedPatternAsync(RenamePattern globalPattern, bool disable)
    {
        if (_editTarget is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        var existing = await db.RenamePatterns
            .FirstOrDefaultAsync(p => p.FolderId == _editTarget.Id && p.IsExcluded && p.GlobalPatternId == globalPattern.Id);
        if (disable && existing is null)
        {
            db.RenamePatterns.Add(new RenamePattern
            {
                Id              = Guid.NewGuid(),
                Name            = $"Exclude: {globalPattern.Name}",
                Pattern         = globalPattern.Pattern,
                Scope           = PatternScope.FolderOverride,
                FolderId        = _editTarget.Id,
                IsExcluded      = true,
                GlobalPatternId = globalPattern.Id,
                Priority        = globalPattern.Priority,
            });
            _disabledInheritedPatternIds.Add(globalPattern.Id);
        }
        else if (!disable && existing is not null)
        {
            db.RenamePatterns.Remove(existing);
            _disabledInheritedPatternIds.Remove(globalPattern.Id);
        }
        await db.SaveChangesAsync();
    }

    private void TestEditPattern()
    {
        if (string.IsNullOrWhiteSpace(_editTestInput)) return;
        var ext  = Path.GetExtension(_editTestInput);
        var kind = Matcher.DetermineFileKind(ext);
        _editTestKind   = kind.ToString();
        _editTestResult = Matcher.ParseFileName(_editTestInput, _editPatterns);
        _editTestNewName = _editTestResult.IsMatched
            ? Matcher.BuildTargetName(_editTestResult, null, kind, ext)
            : null;
    }

    // ── Edit panel – ignore rules ──────────────────────────────────

    private async Task AddEditRuleAsync()
    {
        if (_editTarget is null || string.IsNullOrWhiteSpace(_editNewMask)) return;
        var mask = _editNewMask.Trim().ToLowerInvariant();
        if (_editRules.Any(r => r.Mask.Equals(mask, StringComparison.OrdinalIgnoreCase)))
        {
            ToastService.ShowToast(ToastIntent.Warning, L["settings.toast_mask_exists"]);
            return;
        }
        await using var db = await DbFactory.CreateDbContextAsync();
        db.IgnoreRules.Add(new IgnoreRule
        {
            Id       = Guid.NewGuid(),
            Mask     = mask,
            Scope    = RuleScope.FolderOverride,
            FolderId = _editTarget.Id,
        });
        await db.SaveChangesAsync();
        _editNewMask = "";
        ToastService.ShowToast(ToastIntent.Success, L.Get("settings.toast_rule_added", mask));
        await ReloadEditRulesAsync();
    }

    private async Task DeleteEditRuleAsync(IgnoreRule rule)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.IgnoreRules.FindAsync(rule.Id);
        if (entity is not null) { db.IgnoreRules.Remove(entity); await db.SaveChangesAsync(); }
        ToastService.ShowToast(ToastIntent.Success, L.Get("settings.toast_rule_deleted", rule.Mask));
        await ReloadEditRulesAsync();
    }

    private async Task ReloadEditRulesAsync()
    {
        if (_editTarget is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        _editRules = await db.IgnoreRules
            .Where(r => r.FolderId == _editTarget.Id && r.Scope == RuleScope.FolderOverride)
            .OrderBy(r => r.Mask)
            .ToListAsync();
    }

    // ── Section add/edit ───────────────────────────────────────────

    private void OpenPicker()
    {
        _drives = DriveInfo.GetDrives().Where(d => d.IsReady).ToList();
        _pickerCurrent = null;
        _pickerChildren = [];
        _pickerMode = true;
    }

    private void PickerSelectDrive(string rootPath)
    {
        _pickerCurrent = rootPath.TrimEnd(Path.DirectorySeparatorChar, '/');
        _pickerChildren = GetSafeChildren(_pickerCurrent);
    }

    private void PickerNavigateInto(string dir)
    {
        _pickerCurrent = dir;
        _pickerChildren = GetSafeChildren(dir);
    }

    private void PickerNavigateUp()
    {
        if (_pickerCurrent is null) return;
        var parent = Path.GetDirectoryName(_pickerCurrent);
        if (string.IsNullOrEmpty(parent))
        {
            _pickerCurrent = null;
            _pickerChildren = [];
        }
        else
        {
            _pickerCurrent = parent;
            _pickerChildren = GetSafeChildren(parent);
        }
    }

    private void PickerConfirm()
    {
        if (_pickerCurrent is not null)
        {
            _formPath = _pickerCurrent;
            if (string.IsNullOrWhiteSpace(_formLabel))
                _formLabel = Path.GetFileName(_pickerCurrent) ?? _pickerCurrent;
        }
        _pickerMode = false;
    }

    private static List<string> GetSafeChildren(string dir)
    {
        try { return [.. Directory.GetDirectories(dir).OrderBy(d => d)]; }
        catch { return []; }
    }

    private void OpenSectionDialog(FolderWatcher? section)
    {
        _sectionEditTarget   = section;
        _formPath            = section?.Path ?? "";
        _formLabel           = section?.Label ?? "";
        _formWatch           = section?.WatchEnabled ?? true;
        _formRenameEnabled   = section?.RenameEnabled ?? true;
        _formFolderTypeStr   = (section?.FolderType ?? FolderType.Auto).ToString();
        _pickerMode          = false;
        _sectionDialogHidden = false;
    }

    private async Task SaveSection()
    {
        if (string.IsNullOrWhiteSpace(_formPath) || string.IsNullOrWhiteSpace(_formLabel)) return;
        var folderType = Enum.TryParse<FolderType>(_formFolderTypeStr, out var ft) ? ft : FolderType.Auto;

        await using var db = await DbFactory.CreateDbContextAsync();
        if (_sectionEditTarget is null)
        {
            var section = new FolderWatcher
            {
                Id            = Guid.NewGuid(),
                Path          = _formPath.Trim(),
                Label         = _formLabel.Trim(),
                WatchEnabled  = _formWatch,
                RenameEnabled = _formRenameEnabled,
                FolderType    = _formRenameEnabled ? folderType : FolderType.Auto,
                IsSection     = true,
                CreatedAt     = DateTime.UtcNow,
            };
            db.FolderWatchers.Add(section);
            await db.SaveChangesAsync();
            if (_formWatch) await WatcherService.StartWatcherAsync(section.Id);
            var count = await DiscoverChildrenAsync(db, section);
            _expanded.Add(section.Id);
            ToastService.ShowToast(ToastIntent.Success, L.Get("explorer.toast_section_added", section.Label, count));
        }
        else
        {
            var entity = await db.FolderWatchers.FindAsync(_sectionEditTarget.Id);
            if (entity is null) return;
            var wasEnabled = entity.WatchEnabled;
            entity.Path          = _formPath.Trim();
            entity.Label         = _formLabel.Trim();
            entity.WatchEnabled  = _formWatch;
            entity.RenameEnabled = _formRenameEnabled;
            entity.FolderType    = _formRenameEnabled ? folderType : FolderType.Auto;
            await db.SaveChangesAsync();
            if (!wasEnabled && _formWatch) await WatcherService.StartWatcherAsync(entity.Id);
            else if (wasEnabled && !_formWatch) await WatcherService.StopWatcherAsync(entity.Id);
            ToastService.ShowToast(ToastIntent.Success, L.Get("explorer.toast_section_updated", entity.Label));
        }

        _sectionDialogHidden = true;
        await LoadAsync();
    }

    // ── Delete ─────────────────────────────────────────────────────

    private void AskDelete(FolderWatcher f, bool isSection)
    {
        _deleteTarget    = f;
        _deleteIsSection = isSection;
        _deleteHidden    = false;
    }

    private async Task ConfirmDelete()
    {
        if (_deleteTarget is null) return;
        await WatcherService.StopWatcherAsync(_deleteTarget.Id);
        await using var db = await DbFactory.CreateDbContextAsync();
        if (_deleteIsSection)
        {
            var childList = await db.FolderWatchers
                .Where(f => f.ParentSectionId == _deleteTarget.Id)
                .ToListAsync();
            foreach (var child in childList)
                await WatcherService.StopWatcherAsync(child.Id);
            db.FolderWatchers.RemoveRange(childList);
        }
        var entity = await db.FolderWatchers.FindAsync(_deleteTarget.Id);
        if (entity is not null) { db.FolderWatchers.Remove(entity); await db.SaveChangesAsync(); }
        ToastService.ShowToast(ToastIntent.Success, L.Get("explorer.toast_deleted", _deleteTarget.Label));
        _deleteHidden = true;
        _deleteTarget = null;
        await LoadAsync();
    }

    // ── Watcher toggle ─────────────────────────────────────────────

    private async Task ToggleWatcher(FolderWatcher folder, bool enabled)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.FolderWatchers.FindAsync(folder.Id);
        if (entity is null) return;
        entity.WatchEnabled = enabled;
        await db.SaveChangesAsync();
        folder.WatchEnabled = enabled;
        if (enabled) await WatcherService.StartWatcherAsync(folder.Id);
        else await WatcherService.StopWatcherAsync(folder.Id);
    }

    // ── Subfolder discovery ────────────────────────────────────────

    private async Task RefreshSection(FolderWatcher section)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var count = await DiscoverChildrenAsync(db, section);
        if (count > 0) _expanded.Add(section.Id);
        ToastService.ShowToast(count > 0 ? ToastIntent.Success : ToastIntent.Info,
            count > 0
                ? L.Get("explorer.toast_found_subfolders", count)
                : L["explorer.toast_no_subfolders"]);
        await LoadAsync();
    }

    private async Task<int> DiscoverChildrenAsync(AppDbContext db, FolderWatcher section)
    {
        if (!Directory.Exists(section.Path)) return 0;

        var existingPaths = await db.FolderWatchers
            .Where(f => f.ParentSectionId == section.Id)
            .Select(f => f.Path)
            .ToHashSetAsync();

        var toAdd = new List<FolderWatcher>();
        foreach (var subDir in Directory.GetDirectories(section.Path))
        {
            var norm = subDir.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
            if (existingPaths.Any(p =>
                    string.Equals(
                        p.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar),
                        norm, StringComparison.OrdinalIgnoreCase)))
                continue;

            toAdd.Add(new FolderWatcher
            {
                Id              = Guid.NewGuid(),
                Path            = norm,
                Label           = Path.GetFileName(norm),
                WatchEnabled    = section.WatchEnabled,
                FolderType      = section.FolderType,
                RenameEnabled   = section.RenameEnabled,
                IsSection       = false,
                ParentSectionId = section.Id,
                CreatedAt       = DateTime.UtcNow,
            });
        }

        if (toAdd.Count > 0)
        {
            db.FolderWatchers.AddRange(toAdd);
            await db.SaveChangesAsync();
            foreach (var child in toAdd.Where(c => c.WatchEnabled))
                await WatcherService.StartWatcherAsync(child.Id);
        }

        return toAdd.Count;
    }
}
