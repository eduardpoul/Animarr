@page "/explorer"
@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbFactory
@inject FolderWatcherService WatcherService
@inject IToastService ToastService

<PageTitle>Animarr</PageTitle>

<FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="margin-bottom:20px;gap:12px;">
    <FluentLabel Typo="Typography.H4" Style="margin:0;flex:1;">@L["explorer.title"]</FluentLabel>
    <FluentButton Appearance="Appearance.Accent"
                  IconStart="@(new Icons.Regular.Size20.Add())"
                  Title="@(L["explorer.add_section_button"])"
                  OnClick="@(() => OpenSectionDialog(null))" />
</FluentStack>

@if (_loading)
{
    <div style="display:flex;justify-content:center;align-items:center;padding:80px 0;">
        <FluentProgressRing />
    </div>
}
else if (_sections.Count == 0 && _standalone.Count == 0)
{
    <div style="text-align:center;padding:60px 20px;color:var(--neutral-foreground-hint);">
        <FluentIcon Value="@(new Icons.Regular.Size24.Folder())" Style="opacity:0.3;" />
        <div style="margin-top:16px;font-size:15px;">@L["explorer.empty"]</div>
    </div>
}
else
{
    @foreach (var sect in _sections)
    {
        var children = _children.GetValueOrDefault(sect.Id, []);
        var expanded = _expanded.Contains(sect.Id);

        <div style="border:1px solid var(--neutral-stroke-rest);border-radius:8px;margin-bottom:10px;overflow:hidden;">

            <!-- Section header -->
            <div style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:var(--neutral-layer-2);cursor:pointer;user-select:none;"
                 @onclick="@(() => ToggleExpand(sect.Id))">

                @if (expanded)
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" Style="flex-shrink:0;" />
                }
                else
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.ChevronRight())" Style="flex-shrink:0;" />
                }
                <FluentIcon Value="@(new Icons.Regular.Size20.Folder())" Style="flex-shrink:0;" />

                <span style="font-weight:600;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@sect.Label</span>

                <span style="font-size:11px;color:var(--neutral-foreground-hint);max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex-shrink:1;">
                    @sect.Path
                </span>

                <FluentBadge Appearance="Appearance.Accent" Style="flex-shrink:0;font-size:11px;">
                    @(sect.FolderType switch {
                        FolderType.Series => L["folders.type_series"],
                        FolderType.Movie  => L["folders.type_movie"],
                        _                 => L["folders.type_auto"],
                    })
                </FluentBadge>

                <FluentBadge Appearance="Appearance.Neutral" Style="flex-shrink:0;font-size:11px;">
                    @children.Count
                </FluentBadge>

                <div @onclick:stopPropagation style="display:flex;align-items:center;gap:4px;flex-shrink:0;">
                    <FluentSwitch Value="@sect.WatchEnabled"
                                  ValueChanged="@(async (bool v) => await ToggleWatcher(sect, v))"
                                  Title="@L["explorer.tooltip_monitor"]"
                                  Style="min-width:unset;" />

                    <FluentButton Appearance="Appearance.Stealth"
                                  IconStart="@(new Icons.Regular.Size20.ArrowSync())"
                                  Title="@L["explorer.btn_refresh_tooltip"]"
                                  OnClick="@(() => RefreshSection(sect))" />
                    <FluentButton Appearance="Appearance.Stealth"
                                  IconStart="@(new Icons.Regular.Size20.Edit())"
                                  Title="@L["folders.btn_edit"]"
                                  OnClick="@(() => OpenSectionDialog(sect))" />
                    <FluentButton Appearance="Appearance.Stealth"
                                  IconStart="@(new Icons.Regular.Size20.Delete())"
                                  Title="@L["folders.btn_delete"]"
                                  OnClick="@(() => AskDelete(sect, true))" />
                </div>
            </div>

            <!-- Subfolder rows -->
            @if (expanded)
            {
                @if (children.Count == 0)
                {
                    <div style="padding:10px 14px 10px 52px;font-size:13px;color:var(--neutral-foreground-hint);">
                        @L["explorer.subfolder_empty"]
                    </div>
                }
                else
                {
                    @foreach (var child in children.OrderBy(c => c.Label))
                    {
                        var filesOpen = _openFiles.Contains(child.Id);
                        <div>
                            <div style="display:flex;align-items:center;gap:8px;padding:8px 14px 8px 48px;border-top:1px solid var(--neutral-stroke-subtle);cursor:pointer;user-select:none;"
                                 @onclick="@(() => ToggleFilesOpen(child.Id))">
                                <FluentIcon Value="@(filesOpen ? (Icon)(new Icons.Regular.Size16.ChevronDown()) : new Icons.Regular.Size16.ChevronRight())" Style="flex-shrink:0;opacity:0.7;" />
                                <FluentIcon Value="@(filesOpen ? (Icon)(new Icons.Regular.Size20.FolderOpen()) : new Icons.Regular.Size20.Folder())" Style="flex-shrink:0;opacity:0.7;" />
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@child.Label</div>
                                    <div style="font-size:11px;color:var(--neutral-foreground-hint);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@child.Path</div>
                                </div>
                                <FluentBadge Appearance="Appearance.Neutral" Style="flex-shrink:0;font-size:11px;">
                                    @(child.FolderType switch {
                                        FolderType.Series => L["folders.type_series"],
                                        FolderType.Movie  => L["folders.type_movie"],
                                        _                 => L["folders.type_auto"],
                                    })
                                </FluentBadge>
                                <div @onclick:stopPropagation style="display:flex;align-items:center;gap:4px;flex-shrink:0;">
                                    <FluentSwitch Value="@child.WatchEnabled"
                                                  ValueChanged="@(async (bool v) => await ToggleWatcher(child, v))"
                                                  Title="@L["explorer.tooltip_monitor"]"
                                                  Style="min-width:unset;" />
                                    <FluentButton Appearance="Appearance.Stealth"
                                                  IconStart="@(new Icons.Regular.Size20.Edit())"
                                                  Title="@L["folders.btn_edit"]"
                                                  OnClick="@(() => OpenEditPanel(child))" />
                                    <FluentButton Appearance="Appearance.Stealth"
                                                  IconStart="@(new Icons.Regular.Size20.Delete())"
                                                  Title="@L["folders.btn_delete"]"
                                                  OnClick="@(() => AskDelete(child, false))" />
                                </div>
                            </div>
                            @if (filesOpen)
                            {
                                <FolderScanPanel Folder="child" />
                            }
                        </div>
                    }
                }
            }

        </div>
    }

    @if (_standalone.Count > 0)
    {
        <FluentLabel Typo="Typography.H5" Style="margin:20px 0 10px;">@L["explorer.standalone_title"]</FluentLabel>
        <div style="border:1px solid var(--neutral-stroke-rest);border-radius:8px;overflow:hidden;">
            @foreach (var folder in _standalone)
            {
                var folderFilesOpen = _openFiles.Contains(folder.Id);
                <div>
                    <div style="display:flex;align-items:center;gap:8px;padding:10px 14px;border-bottom:1px solid var(--neutral-stroke-subtle);cursor:pointer;user-select:none;"
                         @onclick="@(() => ToggleFilesOpen(folder.Id))">
                        <FluentIcon Value="@(folderFilesOpen ? (Icon)(new Icons.Regular.Size16.ChevronDown()) : new Icons.Regular.Size16.ChevronRight())" Style="flex-shrink:0;" />
                        <FluentIcon Value="@(folderFilesOpen ? (Icon)(new Icons.Regular.Size20.FolderOpen()) : new Icons.Regular.Size20.Folder())" Style="flex-shrink:0;" />
                        <div style="flex:1;min-width:0;">
                            <div style="font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@folder.Label</div>
                            <div style="font-size:11px;color:var(--neutral-foreground-hint);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@folder.Path</div>
                        </div>
                        <FluentBadge Appearance="Appearance.Neutral" Style="flex-shrink:0;font-size:11px;">
                            @(folder.FolderType switch {
                                FolderType.Series => L["folders.type_series"],
                                FolderType.Movie  => L["folders.type_movie"],
                                _                 => L["folders.type_auto"],
                            })
                        </FluentBadge>
                        <div @onclick:stopPropagation style="display:flex;align-items:center;gap:4px;flex-shrink:0;">
                            <FluentSwitch Value="@folder.WatchEnabled"
                                          ValueChanged="@(async (bool v) => await ToggleWatcher(folder, v))"
                                          Title="@L["explorer.tooltip_monitor"]"
                                          Style="min-width:unset;" />
                            <FluentButton IconStart="@(new Icons.Regular.Size20.Edit())"
                                          Title="@L["folders.btn_edit"]"
                                          OnClick="@(() => OpenEditPanel(folder))" />
                            <FluentButton Appearance="Appearance.Stealth"
                                          IconStart="@(new Icons.Regular.Size20.Delete())"
                                          Title="@L["folders.btn_delete"]"
                                          OnClick="@(() => AskDelete(folder, false))" />
                        </div>
                    </div>
                    @if (folderFilesOpen)
                    {
                        <FolderScanPanel Folder="folder" />
                    }
                </div>
            }
        </div>
    }
}

<!-- ================================================================ -->
<!-- ADD / EDIT SECTION DIALOG -->
<!-- ================================================================ -->
<FluentDialog @bind-Hidden="_sectionDialogHidden" Modal="true" TrapFocus="true" PreventScroll="true" Width="500px">
    <FluentDialogHeader ShowDismiss="true">
        <FluentLabel Typo="Typography.H6">
            @(_sectionEditTarget is null ? L["explorer.dialog_add_title"] : L["explorer.dialog_edit_title"])
        </FluentLabel>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentStack Orientation="Orientation.Vertical" Style="gap:14px;">
            @if (!_pickerMode)
            {
                <div style="display:flex;align-items:flex-end;gap:6px;">
                    <FluentTextField @bind-Value="_formPath"
                                     Label="@(L["folders.field_path_label"])"
                                     Placeholder="@(L["folders.field_path_placeholder"])"
                                     style="flex:1;" />
                    <FluentButton Appearance="Appearance.Outline"
                                  IconStart="@(new Icons.Regular.Size20.FolderOpen())"
                                  Title="@(L["explorer.picker_browse"])"
                                  OnClick="OpenPicker" />
                </div>
            }
            else
            {
                <div>
                    <FluentLabel Style="font-size:13px;font-weight:600;margin-bottom:8px;display:block;">@L["explorer.picker_title"]</FluentLabel>

                    @if (_pickerCurrent is null)
                    {
                        <!-- Drive list -->
                        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;">
                            @foreach (var drive in _drives)
                            {
                                <FluentButton Appearance="Appearance.Outline"
                                              IconStart="@(new Icons.Regular.Size20.HardDrive())"
                                              OnClick="@(() => PickerSelectDrive(drive.RootDirectory.FullName))">
                                    @drive.Name
                                </FluentButton>
                            }
                        </div>
                    }
                    else
                    {
                        <!-- Breadcrumb + Up button -->
                        <div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;min-width:0;">
                            <FluentButton Appearance="Appearance.Stealth"
                                          IconStart="@(new Icons.Regular.Size20.ArrowUp())"
                                          OnClick="PickerNavigateUp"
                                          Title="@(L["explorer.picker_up"])" />
                            <span style="font-size:12px;color:var(--neutral-foreground-hint);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;"
                                  title="@_pickerCurrent">@_pickerCurrent</span>
                        </div>

                        <!-- Subdirectory list -->
                        <div style="max-height:180px;overflow-y:auto;border:1px solid var(--neutral-stroke-rest);border-radius:4px;">
                            @if (_pickerChildren.Count == 0)
                            {
                                <div style="padding:10px;font-size:12px;color:var(--neutral-foreground-hint);">@L["explorer.picker_empty"]</div>
                            }
                            else
                            {
                                @foreach (var dir in _pickerChildren)
                                {
                                    <div style="display:flex;align-items:center;gap:6px;padding:5px 10px;cursor:pointer;border-bottom:1px solid var(--neutral-stroke-subtle);"
                                         @onclick="@(() => PickerNavigateInto(dir))">
                                        <FluentIcon Value="@(new Icons.Regular.Size16.Folder())" />
                                        <span style="font-size:13px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@Path.GetFileName(dir)</span>
                                    </div>
                                }
                            }
                        </div>

                        <!-- Confirm current dir -->
                        <div style="display:flex;justify-content:flex-end;margin-top:8px;gap:6px;">
                            <span style="font-size:12px;color:var(--neutral-foreground-hint);align-self:center;overflow:hidden;text-overflow:ellipsis;max-width:250px;" title="@_pickerCurrent">
                                @L["explorer.picker_selected"] <b>@Path.GetFileName(_pickerCurrent)</b>
                            </span>
                            <FluentButton Appearance="Appearance.Accent" OnClick="PickerConfirm">@L["explorer.picker_select_btn"]</FluentButton>
                            <FluentButton OnClick="@(() => _pickerMode = false)">@L["folders.btn_cancel"]</FluentButton>
                        </div>
                    }
                </div>
            }
            <FluentTextField @bind-Value="_formLabel"
                             Label="@(L["folders.field_name_label"])"
                             Placeholder="@(L["folders.field_name_placeholder"])"
                             style="width:100%;" />
            <FluentSwitch @bind-Value="_formWatch">@L["folders.switch_monitor"]</FluentSwitch>
            <FluentSwitch @bind-Value="_formRenameEnabled">@L["folders.switch_rename"]</FluentSwitch>
            @if (_formRenameEnabled)
            {
                <FluentSelect TOption="string" @bind-Value="_formFolderTypeStr"
                              Label="@(L["folders.content_type_label"])" style="width:100%;">
                    <FluentOption TOption="string" Value="Auto">@L["folders.content_type_auto"]</FluentOption>
                    <FluentOption TOption="string" Value="Series">@L["folders.content_type_series"]</FluentOption>
                    <FluentOption TOption="string" Value="Movie">@L["folders.content_type_movie"]</FluentOption>
                </FluentSelect>
            }
        </FluentStack>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="SaveSection"
                      Disabled="@(string.IsNullOrWhiteSpace(_formPath) || string.IsNullOrWhiteSpace(_formLabel))">
            @L["folders.btn_save"]
        </FluentButton>
        <FluentButton OnClick="@(() => _sectionDialogHidden = true)">@L["folders.btn_cancel"]</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

<!-- ================================================================ -->
<!-- DELETE CONFIRMATION -->
<!-- ================================================================ -->
<FluentDialog @bind-Hidden="_deleteHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader ShowDismiss="true">
        <FluentLabel Typo="Typography.H6">@L["folders.delete_title"]</FluentLabel>
    </FluentDialogHeader>
    <FluentDialogBody>
        @if (_deleteIsSection)
        {
            <FluentLabel>@L.Get("explorer.delete_section_body", _deleteTarget?.Label)</FluentLabel>
        }
        else
        {
            <FluentLabel>@L.Get("folders.delete_body", _deleteTarget?.Label)</FluentLabel>
        }
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmDelete">@L["folders.btn_delete_confirm"]</FluentButton>
        <FluentButton OnClick="@(() => _deleteHidden = true)">@L["folders.btn_cancel"]</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@if (_editTarget is not null)
{
    <FolderEditPanel Folder="_editTarget" OnSaved="HandleEditSaved" OnClosed="CloseEditPanel" />
}




@code {
    private List<FolderWatcher> _sections = [];
    private Dictionary<Guid, List<FolderWatcher>> _children = [];
    private List<FolderWatcher> _standalone = [];
    private bool _loading = true;
    private HashSet<Guid> _expanded = [];

    // ── Section add/edit dialog ────────────────────────────────────
    private bool _sectionDialogHidden = true;
    private FolderWatcher? _sectionEditTarget;
    private string _formPath = "";
    private string _formLabel = "";
    private bool _formWatch = true;
    private bool _formRenameEnabled = true;
    private string _formFolderTypeStr = "Auto";

    // Folder picker (embedded in add dialog)
    private List<DriveInfo> _drives = [];
    private string? _pickerCurrent;
    private List<string> _pickerChildren = [];
    private bool _pickerMode = false;

    private HashSet<Guid> _openFiles = [];

    // ── Edit folder panel ──────────────────────────────────────────
    private FolderWatcher? _editTarget;

    // ── Delete dialog ──────────────────────────────────────────────
    private bool _deleteHidden = true;
    private FolderWatcher? _deleteTarget;
    private bool _deleteIsSection;

    // ── Init ───────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        foreach (var s in _sections.Where(s => _children.ContainsKey(s.Id)))
            _expanded.Add(s.Id);
        _loading = false;
    }

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var all = await db.FolderWatchers.OrderBy(f => f.Label).ToListAsync();
        _sections  = all.Where(f => f.IsSection).ToList();
        _children  = all
            .Where(f => !f.IsSection && f.ParentSectionId.HasValue)
            .GroupBy(f => f.ParentSectionId!.Value)
            .ToDictionary(g => g.Key, g => g.ToList());
        _standalone = all.Where(f => !f.IsSection && !f.ParentSectionId.HasValue).ToList();
    }

    private void ToggleExpand(Guid id)
    {
        if (!_expanded.Remove(id)) _expanded.Add(id);
    }

    private void ToggleFilesOpen(Guid id)
    {
        if (!_openFiles.Remove(id)) _openFiles.Add(id);
    }

    // ── Edit panel ─────────────────────────────────────────────────

    private void OpenEditPanel(FolderWatcher folder) => _editTarget = folder;

    private async Task HandleEditSaved()
    {
        _editTarget = null;
        await LoadAsync();
    }

    private void CloseEditPanel() => _editTarget = null;


    // ── Section add/edit ───────────────────────────────────────────

    private void OpenPicker()
    {
        _drives = DriveInfo.GetDrives().Where(d => d.IsReady).ToList();
        _pickerCurrent = null;
        _pickerChildren = [];
        _pickerMode = true;
    }

    private void PickerSelectDrive(string rootPath)
    {
        _pickerCurrent = rootPath.TrimEnd(Path.DirectorySeparatorChar, '/');
        _pickerChildren = GetSafeChildren(_pickerCurrent);
    }

    private void PickerNavigateInto(string dir)
    {
        _pickerCurrent = dir;
        _pickerChildren = GetSafeChildren(dir);
    }

    private void PickerNavigateUp()
    {
        if (_pickerCurrent is null) return;
        var parent = Path.GetDirectoryName(_pickerCurrent);
        if (string.IsNullOrEmpty(parent))
        {
            _pickerCurrent = null;
            _pickerChildren = [];
        }
        else
        {
            _pickerCurrent = parent;
            _pickerChildren = GetSafeChildren(parent);
        }
    }

    private void PickerConfirm()
    {
        if (_pickerCurrent is not null)
        {
            _formPath = _pickerCurrent;
            if (string.IsNullOrWhiteSpace(_formLabel))
                _formLabel = Path.GetFileName(_pickerCurrent) ?? _pickerCurrent;
        }
        _pickerMode = false;
    }

    private static List<string> GetSafeChildren(string dir)
    {
        try { return [.. Directory.GetDirectories(dir).OrderBy(d => d)]; }
        catch { return []; }
    }

    private void OpenSectionDialog(FolderWatcher? section)
    {
        _sectionEditTarget   = section;
        _formPath            = section?.Path ?? "";
        _formLabel           = section?.Label ?? "";
        _formWatch           = section?.WatchEnabled ?? true;
        _formRenameEnabled   = section?.RenameEnabled ?? true;
        _formFolderTypeStr   = (section?.FolderType ?? FolderType.Auto).ToString();
        _pickerMode          = false;
        _sectionDialogHidden = false;
    }

    private async Task SaveSection()
    {
        if (string.IsNullOrWhiteSpace(_formPath) || string.IsNullOrWhiteSpace(_formLabel)) return;
        var folderType = Enum.TryParse<FolderType>(_formFolderTypeStr, out var ft) ? ft : FolderType.Auto;

        await using var db = await DbFactory.CreateDbContextAsync();
        if (_sectionEditTarget is null)
        {
            var section = new FolderWatcher
            {
                Id            = Guid.NewGuid(),
                Path          = _formPath.Trim(),
                Label         = _formLabel.Trim(),
                WatchEnabled  = _formWatch,
                RenameEnabled = _formRenameEnabled,
                FolderType    = _formRenameEnabled ? folderType : FolderType.Auto,
                IsSection     = true,
                CreatedAt     = DateTime.UtcNow,
            };
            db.FolderWatchers.Add(section);
            await db.SaveChangesAsync();
            if (_formWatch) await WatcherService.StartWatcherAsync(section.Id);
            var count = await DiscoverChildrenAsync(db, section);
            _expanded.Add(section.Id);
            ToastService.ShowToast(ToastIntent.Success, L.Get("explorer.toast_section_added", section.Label, count));
        }
        else
        {
            var entity = await db.FolderWatchers.FindAsync(_sectionEditTarget.Id);
            if (entity is null) return;
            var wasEnabled = entity.WatchEnabled;
            entity.Path          = _formPath.Trim();
            entity.Label         = _formLabel.Trim();
            entity.WatchEnabled  = _formWatch;
            entity.RenameEnabled = _formRenameEnabled;
            entity.FolderType    = _formRenameEnabled ? folderType : FolderType.Auto;
            await db.SaveChangesAsync();
            if (!wasEnabled && _formWatch) await WatcherService.StartWatcherAsync(entity.Id);
            else if (wasEnabled && !_formWatch) await WatcherService.StopWatcherAsync(entity.Id);
            ToastService.ShowToast(ToastIntent.Success, L.Get("explorer.toast_section_updated", entity.Label));
        }

        _sectionDialogHidden = true;
        await LoadAsync();
    }

    // ── Delete ─────────────────────────────────────────────────────

    private void AskDelete(FolderWatcher f, bool isSection)
    {
        _deleteTarget    = f;
        _deleteIsSection = isSection;
        _deleteHidden    = false;
    }

    private async Task ConfirmDelete()
    {
        if (_deleteTarget is null) return;
        await WatcherService.StopWatcherAsync(_deleteTarget.Id);
        await using var db = await DbFactory.CreateDbContextAsync();
        if (_deleteIsSection)
        {
            var childList = await db.FolderWatchers
                .Where(f => f.ParentSectionId == _deleteTarget.Id)
                .ToListAsync();
            foreach (var child in childList)
                await WatcherService.StopWatcherAsync(child.Id);
            db.FolderWatchers.RemoveRange(childList);
        }
        var entity = await db.FolderWatchers.FindAsync(_deleteTarget.Id);
        if (entity is not null) { db.FolderWatchers.Remove(entity); await db.SaveChangesAsync(); }
        ToastService.ShowToast(ToastIntent.Success, L.Get("explorer.toast_deleted", _deleteTarget.Label));
        _deleteHidden = true;
        _deleteTarget = null;
        await LoadAsync();
    }

    // ── Watcher toggle ─────────────────────────────────────────────

    private async Task ToggleWatcher(FolderWatcher folder, bool enabled)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var entity = await db.FolderWatchers.FindAsync(folder.Id);
        if (entity is null) return;
        entity.WatchEnabled = enabled;
        await db.SaveChangesAsync();
        folder.WatchEnabled = enabled;
        if (enabled) await WatcherService.StartWatcherAsync(folder.Id);
        else await WatcherService.StopWatcherAsync(folder.Id);
    }

    // ── Subfolder discovery ────────────────────────────────────────

    private async Task RefreshSection(FolderWatcher section)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var count = await DiscoverChildrenAsync(db, section);
        if (count > 0) _expanded.Add(section.Id);
        ToastService.ShowToast(count > 0 ? ToastIntent.Success : ToastIntent.Info,
            count > 0
                ? L.Get("explorer.toast_found_subfolders", count)
                : L["explorer.toast_no_subfolders"]);
        await LoadAsync();
    }

    private async Task<int> DiscoverChildrenAsync(AppDbContext db, FolderWatcher section)
    {
        if (!Directory.Exists(section.Path)) return 0;

        var existingPaths = await db.FolderWatchers
            .Where(f => f.ParentSectionId == section.Id)
            .Select(f => f.Path)
            .ToHashSetAsync();

        var toAdd = new List<FolderWatcher>();
        foreach (var subDir in Directory.GetDirectories(section.Path))
        {
            var norm = subDir.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
            if (existingPaths.Any(p =>
                    string.Equals(
                        p.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar),
                        norm, StringComparison.OrdinalIgnoreCase)))
                continue;

            toAdd.Add(new FolderWatcher
            {
                Id              = Guid.NewGuid(),
                Path            = norm,
                Label           = Path.GetFileName(norm),
                WatchEnabled    = section.WatchEnabled,
                FolderType      = section.FolderType,
                RenameEnabled   = section.RenameEnabled,
                IsSection       = false,
                ParentSectionId = section.Id,
                CreatedAt       = DateTime.UtcNow,
            });
        }

        if (toAdd.Count > 0)
        {
            db.FolderWatchers.AddRange(toAdd);
            await db.SaveChangesAsync();
            foreach (var child in toAdd.Where(c => c.WatchEnabled))
                await WatcherService.StartWatcherAsync(child.Id);
        }

        return toAdd.Count;
    }
}
