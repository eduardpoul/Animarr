@page "/renames"
@page "/history"
@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IRenameService RenameService
@inject IToastService ToastService

<PageTitle>Animarr</PageTitle>

<FluentLabel Typo="Typography.H4" Style="margin-bottom:16px;">@L["history.title"]</FluentLabel>

<FluentStack Orientation="Orientation.Horizontal" Style="margin-bottom:16px;gap:10px;flex-wrap:wrap;"
             VerticalAlignment="VerticalAlignment.Bottom">
    <FluentSelect TOption="string" Value="@_filterFolder" ValueChanged="@((string v) => { _filterFolder = v; StateHasChanged(); })" Label="@(L["history.filter_folder_label"])" Style="min-width:200px;">
        <FluentOption Value="">@L["history.filter_folder_all"]</FluentOption>
        @foreach (var f in _allFolders)
        {
            <FluentOption Value="@f.Id.ToString()">@f.Label</FluentOption>
        }
    </FluentSelect>
    <FluentSelect TOption="string" Value="@_filterStatus" ValueChanged="@((string v) => { _filterStatus = v; StateHasChanged(); })" Label="@(L["history.filter_status_label"])" Style="min-width:160px;">
        <FluentOption Value="">@L["history.filter_status_all"]</FluentOption>
        <FluentOption Value="Renamed">@L["history.status_renamed"]</FluentOption>
        <FluentOption Value="Skipped">@L["history.status_skipped"]</FluentOption>
        <FluentOption Value="Error">@L["history.status_error"]</FluentOption>
        <FluentOption Value="Reverted">@L["history.status_reverted"]</FluentOption>
    </FluentSelect>
    <FluentButton IconStart="@(new Icons.Regular.Size20.Dismiss())" Title="@L["history.btn_reset_filters"]" OnClick="ResetFilters" />
</FluentStack>

@if (_loading)
{
    <div style="display:flex;justify-content:center;align-items:center;padding:80px 0;">
        <FluentProgressRing />
    </div>
}
else
{
    <FluentDataGrid Items="@FilteredItems()" TGridItem="RenameHistory"
                    ShowHover="true" Pagination="@_pagination"
                    RowSize="DataGridRowSize.Medium"
                    Style="font-size:13px;width:100%;">
        <TemplateColumn Title="@(L["history.col_date"])" Width="120px">
            @context.ProcessedAt.ToLocalTime().ToString("dd.MM.yy HH:mm")
        </TemplateColumn>
        <TemplateColumn Title="@(L["history.col_folder"])" Width="130px">
            <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block;" title="@(_allFolders.FirstOrDefault(f => f.Id == context.FolderId)?.Label ?? "—")">
                @(_allFolders.FirstOrDefault(f => f.Id == context.FolderId)?.Label ?? "—")
            </span>
        </TemplateColumn>
        <TemplateColumn Title="@(L["history.col_original_name"])">
            <code style="font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block;">@Path.GetFileName(context.OriginalPath)</code>
        </TemplateColumn>
        <TemplateColumn Title="" Width="28px" Align="Align.Center">
            <span style="color:var(--neutral-foreground-hint);">→</span>
        </TemplateColumn>
        <TemplateColumn Title="@(L["history.col_new_name"])">
            <code style="font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block;">@Path.GetFileName(context.NewPath)</code>
        </TemplateColumn>
        <TemplateColumn Title="@(L["history.col_status"])" Width="110px">
            <FluentBadge Appearance="@GetStatusAppearance(context.Status)">@GetStatusLabel(context.Status)</FluentBadge>
        </TemplateColumn>
        <TemplateColumn Title="" Width="52px" Align="Align.Center">
            @if (context.Status == RenameStatus.Renamed && !context.IsReverted)
            {
                <FluentButton Appearance="Appearance.Stealth"
                              IconStart="@(new Icons.Regular.Size20.ArrowCounterclockwise())"
                              Title="@(L["history.btn_revert"])"
                              Style="margin-right:8px;"
                              OnClick="@(() => AskRevert(context))" />
            }
        </TemplateColumn>
    </FluentDataGrid>
    <FluentPaginator State="@_pagination" />
}

<FluentDialog @bind-Hidden="_revertHidden" Modal="true" TrapFocus="true" PreventScroll="true">
    <FluentDialogHeader ShowDismiss="true">
        <FluentLabel Typo="Typography.H6">@L["history.revert_dialog_title"]</FluentLabel>
    </FluentDialogHeader>
    <FluentDialogBody>
        <FluentLabel>
            @L["history.revert_dialog_body"]<br />
            <b>@Path.GetFileName(_revertTarget?.NewPath ?? "")</b>
            &nbsp;→&nbsp;
            <b>@Path.GetFileName(_revertTarget?.OriginalPath ?? "")</b>
        </FluentLabel>
    </FluentDialogBody>
    <FluentDialogFooter>
        <FluentButton Appearance="Appearance.Accent" OnClick="ConfirmRevert">@L["history.btn_revert_confirm"]</FluentButton>
        <FluentButton OnClick="@(() => _revertHidden = true)">@L["history.btn_cancel"]</FluentButton>
    </FluentDialogFooter>
</FluentDialog>

@code {
    private List<RenameHistory> _history = [];
    private List<FolderWatcher> _allFolders = [];
    private bool _loading = true;
    private string _filterFolder = "";
    private string _filterStatus = "";
    private PaginationState _pagination = new() { ItemsPerPage = 50 };

    private bool _revertHidden = true;
    private RenameHistory? _revertTarget;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _allFolders = await db.FolderWatchers.OrderBy(f => f.Label).ToListAsync();
        _history = await db.RenameHistories.OrderByDescending(h => h.ProcessedAt).ToListAsync();
    }

    private void ResetFilters() { _filterFolder = ""; _filterStatus = ""; }

    private IQueryable<RenameHistory> FilteredItems()
    {
        var q = _history.AsQueryable();
        if (!string.IsNullOrEmpty(_filterFolder) && Guid.TryParse(_filterFolder, out var fid))
            q = q.Where(h => h.FolderId == fid);
        if (!string.IsNullOrEmpty(_filterStatus) && Enum.TryParse<RenameStatus>(_filterStatus, out var st))
            q = q.Where(h => h.Status == st);
        return q;
    }

    private void AskRevert(RenameHistory r) { _revertTarget = r; _revertHidden = false; }

    private async Task ConfirmRevert()
    {
        if (_revertTarget is null) return;
        var ok = await RenameService.RevertAsync(_revertTarget.Id);
        ToastService.ShowToast(ok ? ToastIntent.Success : ToastIntent.Error,
            ok ? L["history.toast_revert_ok"] : L["history.toast_revert_fail"]);
        _revertHidden = true;
        _revertTarget = null;
        await LoadAsync();
    }

    private string GetStatusLabel(RenameStatus s) => s switch
    {
        RenameStatus.Renamed => L["history.status_renamed"],
        RenameStatus.Skipped => L["history.status_skipped"],
        RenameStatus.Error => L["history.status_error"],
        RenameStatus.Reverted => L["history.status_reverted"],
        _ => "—"
    };

    private static Appearance GetStatusAppearance(RenameStatus s) => s switch
    {
        RenameStatus.Renamed  => Appearance.Accent,
        _                     => Appearance.Neutral
    };
}
